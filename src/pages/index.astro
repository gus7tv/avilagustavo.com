---
import BaseHead from "../components/BaseHead.astro";
import HeroMouseDistortion from "../components/HeroMouseDistortion.astro";
import ProjectsMonitor from "../components/ProjectsMonitor.astro";
import ScrollSpace3D from "../components/ScrollSpace3D.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";
import { X } from "lucide";

const projects = (await getCollection("proyectos"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const currentYear = new Date().getFullYear();

const socialLinks = [
	{ label: "GitHub", href: "https://github.com/gus7tv" },
	{
		label: "LinkedIn",
		href: "https://www.linkedin.com/in/gustavo-avila-2a153311b/",
	},
	{ label: "X", href: "https://x.com/gus7tv_" },
];

const xIconPaths = X.map(([, attrs]) => attrs);
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="portfolio-home">
		<div class="noise"></div>
		<div class="home-shell kinetic-grid">
			<div class="home-main">
				<header class="topbar">
					<div class="topbar__brand" aria-label="Gustavo Avila">
						<img
							class="topbar__brand-logo"
							src="/Logo-G.jpg"
							alt="Logo Gustavo Avila"
							width="96"
							height="96"
							decoding="async"
							fetchpriority="high"
						/>
						<small class="topbar__brand-badge topbar__brand-name">Gustavo Avila</small>
					</div>

					<div class="topbar__actions">
						<nav class="topbar__social" aria-label="Social links">
							<a
								class="topbar__social-link"
								href="https://www.linkedin.com/in/gustavo-avila-2a153311b/"
								target="_blank"
								rel="noreferrer"
								aria-label="LinkedIn"
							>
								<svg
									class="topbar__social-icon topbar__social-icon--brand"
									aria-hidden="true"
									viewBox="0 0 24 24"
								>
									<path
										fill="currentColor"
										d="M20.45 20.45h-3.56v-5.58c0-1.33-.02-3.03-1.85-3.03c-1.85 0-2.13 1.44-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85c3.61 0 4.28 2.38 4.28 5.48v6.26ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14a2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45Z"
									/>
								</svg>
							</a>
							<a
								class="topbar__social-link"
								href="https://github.com/gus7tv"
								target="_blank"
								rel="noreferrer"
								aria-label="GitHub"
							>
								<svg
									class="topbar__social-icon topbar__social-icon--brand"
									aria-hidden="true"
									viewBox="0 0 24 24"
								>
									<path
										fill="currentColor"
										d="M12 2C6.48 2 2 6.58 2 12.23c0 4.51 2.87 8.34 6.84 9.69c.5.1.68-.22.68-.48c0-.24-.01-1.04-.01-1.89c-2.78.62-3.37-1.21-3.37-1.21c-.45-1.18-1.11-1.49-1.11-1.49c-.91-.64.07-.63.07-.63c1 .08 1.53 1.05 1.53 1.05c.9 1.57 2.36 1.12 2.94.86c.09-.67.35-1.12.64-1.37c-2.22-.26-4.56-1.14-4.56-5.08c0-1.12.39-2.03 1.03-2.75c-.1-.26-.45-1.31.1-2.74c0 0 .84-.28 2.75 1.05A9.33 9.33 0 0 1 12 6.84a9.3 9.3 0 0 1 2.5.35c1.9-1.33 2.74-1.05 2.74-1.05c.56 1.43.21 2.48.11 2.74c.64.72 1.03 1.63 1.03 2.75c0 3.95-2.34 4.82-4.57 5.07c.36.32.69.95.69 1.92c0 1.39-.01 2.5-.01 2.84c0 .27.18.59.69.48A10.24 10.24 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z"
									/>
								</svg>
							</a>
							<a
								class="topbar__social-link"
								href="https://x.com/gus7tv_"
								target="_blank"
								rel="noreferrer"
								aria-label="X"
							>
								<svg
									class="topbar__social-icon"
									aria-hidden="true"
									viewBox="0 0 24 24"
									fill="none"
									xmlns="http://www.w3.org/2000/svg"
								>
									{
										xIconPaths.map((attrs) => (
											<path d={attrs.d} />
										))
									}
								</svg>
							</a>
						</nav>
						<a href="#contacto" class="topbar__cta">Contact</a>
					</div>
				</header>

				<main>
					<section id="inicio" class="z-space" data-z-space data-active-panel="hero">
						<span id="proyectos" class="z-space__anchor z-space__anchor--projects" aria-hidden="true"></span>
						<div class="z-space__viewport">
							<ScrollSpace3D />
							<HeroMouseDistortion />

							<section class="hero z-panel z-panel--hero" aria-label="Hero">
								<div class="hero__headline">
									<div class="hero__headline-sequence">
										<h1 class="hero__name" aria-label="Gustavo Avila">
											<span>GUSTAVO</span>
											<span>AVILA</span>
										</h1>
										<p class="hero__phase hero__phase--creative">Creative Developer & UX Engineer</p>
										<p class="hero__phase hero__phase--based">Based in Bogota, CO</p>
										<p class="hero__phase hero__phase--slogan">
											Bridging the gap between design and development
										</p>
									</div>
								</div>
							</section>

							<a class="hero__scroll-hint" href="#proyectos" aria-label="Go to projects">
								<span class="hero__scroll-wheel" aria-hidden="true"></span>
								<span class="hero__scroll-label" aria-hidden="true">scroll</span>
							</a>

							<section class="section-block z-panel z-panel--projects" aria-label="Selected projects">
								<ProjectsMonitor projects={projects} />
							</section>
						</div>
					</section>

					<section id="contacto" class="section-block section-block--contact">
						<div class="contact-copy">
							<h2>LET'S TALK</h2>
							<p>
								If you've made it this far, I'd love to hear from you
								about your proposal, idea, or project.
							</p>

							<div class="contact-links">
								{socialLinks.map((item) => (
									<a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
										{item.label}
									</a>
								))}
							</div>
						</div>

						<form
							class="contact-form"
							id="form"
							name="contact"
							action="/ty"
							method="POST"
							data-netlify="true"
							data-netlify-recaptcha="true"
						>
							<input type="hidden" name="form-name" value="contact" />
							<label>
								<span>Name</span>
								<input type="text" name="nombre" placeholder="Your name" autocomplete="name" required />
							</label>

							<label>
								<span>Email address</span>
								<input
									type="email"
									name="correo"
									placeholder="email@domain.com"
									autocomplete="email"
									required
								/>
							</label>

							<label>
								<span>Message</span>
								<textarea
									name="mensaje"
									rows="5"
									placeholder="Tell me what you're building."
									required
								></textarea>
							</label>

							<div data-netlify-recaptcha="true"></div>

							<button class="topbar__cta contact-submit-button" type="submit">SEND MESSAGE</button>
						</form>
					</section>
				</main>

				<footer class="page-footer">
						<p>{`©${currentYear} GUSTAVO AVILA · ALL RIGHTS RESERVED`}</p>
					<div>
						{socialLinks.map((item) => (
							<a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
								{item.label}
							</a>
						))}
					</div>
				</footer>
			</div>
		</div>
	</body>
</html>

<style is:global>
	.portfolio-home {
		background: #000;
		color: #bdc7d9;
		overflow-x: clip;
	}

	.kinetic-grid {
		background-image:
			linear-gradient(rgba(71, 223, 155, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(71, 223, 155, 0.04) 1px, transparent 1px);
		background-size: 72px 72px, 72px 72px;
		background-position: 0 0, 0 0;
	}

	.home-shell {
		position: relative;
		min-height: 100vh;
		overflow-x: clip;
	}

	.home-main {
		position: relative;
	}

	.topbar {
		position: sticky;
		top: 0;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem 2rem;
		border-bottom: 1px solid rgba(71, 223, 155, 0.08);
		background: rgba(0, 0, 0, 0.78);
		backdrop-filter: blur(16px);
	}

	.topbar__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.9rem;
	}

	.topbar__brand span,
	.topbar__brand small {
		line-height: 1;
	}

	.topbar__brand-logo {
		display: block;
		width: 2.7rem;
		height: 2.7rem;
		border-radius: 0.95rem;
		object-fit: cover;
		box-shadow:
			0 0 0 1px rgba(71, 223, 155, 0.12),
			0 10px 24px rgba(0, 0, 0, 0.24);
	}

	.topbar__brand-badge {
		display: inline-flex;
		align-items: center;
		font-family: "Inter", sans-serif;
		font-size: 1.9rem;
		color: #f4f7fb;
	}

	.topbar__brand-name {
		font-family: "Inter", sans-serif;
		font-size: 1.55rem;
		font-weight: 400;
		letter-spacing: 0;
		text-transform: none;
	}

	.topbar__actions {
		--topbar-action-gap: 0.9rem;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		flex-wrap: nowrap;
		gap: var(--topbar-action-gap);
	}

	.topbar__social {
		display: flex;
		align-items: center;
		gap: var(--topbar-action-gap);
		flex: 0 0 auto;
	}

	.topbar__actions .topbar__cta {
		width: auto;
		flex: 0 0 auto;
	}

	.topbar__social-link,
	.page-footer a,
	.contact-links a {
		color: #bdc7d9;
		font-family: "Inter", sans-serif;
		font-size: 0.82rem;
		letter-spacing: 0.04em;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.topbar__social-link {
		display: grid;
		height: 2.5rem;
		width: 2.5rem;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 1rem;
		background: rgba(0, 0, 0, 0.72);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.topbar__social-link:hover,
	.page-footer a:hover,
	.contact-links a:hover {
		color: #47df9b;
	}

	.topbar__social-link:hover {
		transform: translateY(-2px);
		border-color: rgba(71, 223, 155, 0.5);
		background: rgba(0, 0, 0, 0.92);
		box-shadow: 0 0 16px rgba(71, 223, 155, 0.08);
	}

	.topbar__social-icon {
		width: 1rem;
		height: 1rem;
		flex: none;
		stroke: currentColor;
		stroke-width: 1.9;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.topbar__social-icon--brand {
		stroke: none;
	}

	.topbar__cta {
		--radii: 1rem;
		--size: 0.78rem;
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		cursor: pointer;
		width: 100%;
		padding: 0.7rem 0.9rem;
		min-width: 0;
		max-width: 164px;
		min-height: 44px;
		font-size: var(--size, 1rem);
		font-weight: 500;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
		text-wrap: balance;
		transition:
			border-color 180ms ease,
			color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
		border: 1px solid rgba(255, 255, 255, 0.28);
		border-radius: var(--radii);
		background: rgba(0, 0, 0, 0.72);
		color: rgba(245, 248, 255, 0.94) !important;
		backdrop-filter: blur(20px);
		font-family: "Inter", sans-serif;
		letter-spacing: 0.04em;
	}

	.topbar__cta:hover {
		color: #47df9b !important;
		transform: translateY(-1px);
		border-color: rgba(71, 223, 155, 0.5);
		background: rgba(0, 0, 0, 0.92);
		box-shadow: 0 0 16px rgba(71, 223, 155, 0.08);
	}

	.topbar__cta:is(:focus, :focus-visible, :active) {
		outline: none;
		box-shadow:
			0 0 0 3px rgba(71, 223, 155, 0.14),
			0 0 0 6px rgba(71, 223, 155, 0.2);
		border-color: rgba(71, 223, 155, 0.62);
		color: #47df9b !important;
	}

	.contact-submit-button {
		max-width: none;
		width: 100%;
	}

	main {
		padding: 0 2rem 4rem;
	}

	.section-block,
	.page-footer {
		max-width: 1280px;
		margin: 0 auto;
	}

	.z-space {
		--hero-opacity: 1;
		--hero-y: 0vh;
		--hero-z: 0px;
		--hero-tilt: 0deg;
		--hero-scale: 1;
		--hero-headline-scroll-y: 0vh;
		--hero-seq-title-opacity: 1;
		--hero-seq-creative-opacity: 0;
		--hero-seq-based-opacity: 0;
		--hero-seq-slogan-opacity: 0;
		--projects-opacity: 0;
		--projects-y: 18vh;
		--projects-z: -720px;
		--projects-tilt: -8deg;
		--projects-scale: 0.82;
		--projects-reveal: 0%;
		--projects-reveal-edge: 10%;
		--projects-reveal-x: 50%;
		--projects-reveal-y: 44%;
		--scroll-hint-opacity: 1;
		position: relative;
		min-height: 320vh;
		margin: 0 auto;
	}

	.z-space__anchor {
		position: absolute;
		left: 0;
		width: 1px;
		height: 1px;
		pointer-events: none;
	}

	.z-space__anchor--projects {
		top: calc(105vh + 4rem);
	}

	.z-space__viewport {
		position: sticky;
		top: 82px;
		height: calc(100vh - 82px);
		min-height: 620px;
		overflow: hidden;
		perspective: 1200px;
		perspective-origin: 50% 50%;
		isolation: isolate;
	}

	.z-space__viewport::before,
	.z-space__viewport::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.z-space__viewport::before {
		background:
			linear-gradient(180deg, rgba(0, 0, 0, 0.68), transparent 18%, transparent 78%, rgba(0, 0, 0, 0.72));
	}

	.z-space__viewport::after {
		display: none;
	}

	.z-panel {
		position: absolute;
		inset: 0;
		z-index: 2;
		width: min(100%, 1280px);
		margin: auto;
		transform-style: preserve-3d;
		will-change: transform, opacity;
	}

	.z-panel--hero {
		opacity: var(--hero-opacity);
		transform:
			translate3d(0, var(--hero-y), var(--hero-z))
			rotateX(var(--hero-tilt))
			scale(var(--hero-scale));
	}

	.z-panel.z-panel--projects {
		display: flex;
		flex-direction: column;
		justify-content: center;
		max-width: 1280px;
		padding: clamp(1.5rem, 3vw, 2.6rem) 0;
		opacity: var(--projects-opacity);
		transform:
			translate3d(0, var(--projects-y), 0)
			scale(var(--projects-scale));
		-webkit-mask-image: radial-gradient(
			circle at var(--projects-reveal-x) var(--projects-reveal-y),
			#000 0 var(--projects-reveal),
			rgba(0, 0, 0, 0.8) calc(var(--projects-reveal) + 4%),
			transparent var(--projects-reveal-edge)
		);
		mask-image: radial-gradient(
			circle at var(--projects-reveal-x) var(--projects-reveal-y),
			#000 0 var(--projects-reveal),
			rgba(0, 0, 0, 0.8) calc(var(--projects-reveal) + 4%),
			transparent var(--projects-reveal-edge)
		);
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		-webkit-mask-size: 100% 100%;
		mask-size: 100% 100%;
		contain: paint;
	}

	.z-space[data-active-panel="hero"] .z-panel--projects,
	.z-space[data-active-panel="projects"] .z-panel--hero {
		pointer-events: none;
	}

	.hero {
		--hero-vortex-offset: 1.1rem;
		--hero-headline-offset: 3.15rem;
		width: 100%;
		position: relative;
		height: 100%;
		min-height: 100%;
		padding: 0;
		overflow: hidden;
	}

	.z-panel.hero {
		height: 100%;
		min-height: 100%;
		padding: 0;
	}

	.hero,
	.hero__name {
		-webkit-user-select: none;
		user-select: none;
	}

	.page-footer p {
		font-family: "Inter", sans-serif;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.hero__headline {
		position: absolute;
		inset: 0;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	.hero__headline-sequence {
		position: relative;
		display: grid;
		place-items: center;
		width: 100%;
		padding-inline: clamp(0.4rem, 1.8vw, 1.5rem);
		transform: translateY(clamp(108px, 13.5vh, 182px));
	}

	.hero__scroll-hint {
		position: absolute;
		left: 50%;
		bottom: 2.15rem;
		z-index: 6;
		display: flex;
		width: 1.9rem;
		height: 3.15rem;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(126, 246, 196, 0.78);
		border-radius: 999px;
		background:
			linear-gradient(180deg, rgba(126, 246, 196, 0.08), transparent 62%),
			rgba(0, 0, 0, 0.14);
		box-shadow:
			0 0 0 1px rgba(237, 255, 247, 0.05) inset,
			0 0 16px rgba(71, 223, 155, 0.18),
			0 12px 30px rgba(0, 0, 0, 0.28);
		color: #edfff7;
		opacity: var(--scroll-hint-opacity);
		pointer-events: auto;
		text-decoration: none;
		transform: translateX(-50%);
		transition:
			border-color 180ms ease,
			opacity 220ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
		will-change: opacity, transform;
	}

	.hero__scroll-hint:hover {
		border-color: rgba(237, 255, 247, 0.86);
		box-shadow:
			0 0 0 1px rgba(237, 255, 247, 0.08) inset,
			0 0 22px rgba(71, 223, 155, 0.28),
			0 16px 34px rgba(0, 0, 0, 0.36);
		transform: translateX(-50%) translateY(-2px);
	}

	.hero__scroll-wheel {
		width: 0.32rem;
		height: 0.68rem;
		border-radius: 999px;
		background: #7ef6c4;
		box-shadow:
			0 0 12px rgba(126, 246, 196, 0.82),
			0 0 22px rgba(71, 223, 155, 0.32);
		animation: hero-scroll-wheel 2s ease-in-out infinite;
		transform: translateY(34%);
	}

	.hero__scroll-label {
		position: absolute;
		top: calc(100% + 0.52rem);
		left: 50%;
		color: rgba(237, 255, 247, 0.72);
		font-family: "IBM Plex Mono", monospace;
		font-size: 0.58rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		line-height: 1;
		text-transform: uppercase;
		transform: translateX(-50%);
	}

	.hero__name {
		margin: 0;
		--title-shift-x: 0;
		--title-shift-y: 0;
		--title-tilt: 0;
		--title-glow: 0;
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.22em;
		width: 100%;
		font-family: "Bebas Neue", sans-serif;
		font-size: clamp(5.8rem, 19.5vw, 21rem);
		font-weight: 500;
		line-height: 0.92;
		letter-spacing: 0;
		white-space: nowrap;
		color: #f4f7fb;
		opacity: var(--hero-seq-title-opacity);
		transform:
			translate3d(
				calc(var(--title-shift-x) * 1px),
				calc(var(--title-shift-y) * 1px),
				0
			)
			rotate(calc(var(--title-tilt) * 1deg));
		text-shadow:
			0 0 calc(10px + var(--title-glow) * 5px) rgba(255, 255, 255, calc(0.03 + var(--title-glow) * 0.03)),
			0 0 calc(18px + var(--title-glow) * 12px) rgba(120, 255, 196, calc(0.02 + var(--title-glow) * 0.035));
		transition:
			transform 260ms ease-out,
			text-shadow 320ms ease-out,
			opacity 200ms linear;
		will-change: transform, text-shadow, opacity;
		pointer-events: none;
	}

