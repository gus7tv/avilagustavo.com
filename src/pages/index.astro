	.z-space {
		--hero-opacity: 1;
		--hero-y: 0vh;
		--hero-z: 0px;
		--hero-tilt: 0deg;
		--hero-scale: 1;
		--hero-headline-scroll-y: 0vh;
		--hero-seq-title-opacity: 1;
		--hero-seq-creative-opacity: 0;
		--hero-seq-based-opacity: 0;
		--hero-seq-slogan-opacity: 0;
		--hero-seq-creative-y: 0vh;
		--hero-seq-based-y: 0vh;
		--projects-opacity: 0;
		--projects-y: 18vh;
		--projects-z: -720px;
		--projects-tilt: -8deg;
		--projects-scale: 0.82;
		--projects-reveal: 0%;
		--projects-reveal-edge: 10%;
		--projects-reveal-x: 50%;
		--projects-reveal-y: 44%;
		--scroll-hint-opacity: 1;
		position: relative;
		min-height: 320vh;
		margin: 0 auto;
	}

	.z-space__anchor {
		position: absolute;
		left: 0;
		width: 1px;
		height: 1px;
		pointer-events: none;
	}

	.z-space__anchor--projects {
		top: calc(105vh + 4rem);
	}

	.z-space__viewport {
		position: sticky;
		top: 82px;
		height: calc(100vh - 82px);
		min-height: 620px;
		overflow: hidden;
		perspective: 1200px;
		perspective-origin: 50% 50%;
		isolation: isolate;
	}

	.z-space__viewport::before,
	.z-space__viewport::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.z-space__viewport::before {
		background:
			linear-gradient(180deg, rgba(0, 0, 0, 0.68), transparent 18%, transparent 78%, rgba(0, 0, 0, 0.72));
	}

	.z-space__viewport::after {
		display: none;
	}

	.z-panel {
		position: absolute;
		inset: 0;
		z-index: 2;
		width: min(100%, 1280px);
		margin: auto;
		transform-style: preserve-3d;
		will-change: transform, opacity;
	}

	.z-panel--hero {
		opacity: var(--hero-opacity);
		transform:
			translate3d(0, var(--hero-y), var(--hero-z))
			rotateX(var(--hero-tilt))
			scale(var(--hero-scale));
	}

	.z-panel.z-panel--projects {
		display: flex;
		flex-direction: column;
		justify-content: center;
		max-width: 1280px;
		padding: clamp(1.5rem, 3vw, 2.6rem) 0;
		opacity: var(--projects-opacity);
		transform:
			translate3d(0, var(--projects-y), 0)
			scale(var(--projects-scale));
		-webkit-mask-image: radial-gradient(
			circle at var(--projects-reveal-x) var(--projects-reveal-y),
			#000 0 var(--projects-reveal),
			rgba(0, 0, 0, 0.8) calc(var(--projects-reveal) + 4%),
			transparent var(--projects-reveal-edge)
		);
		mask-image: radial-gradient(
			circle at var(--projects-reveal-x) var(--projects-reveal-y),
			#000 0 var(--projects-reveal),
			rgba(0, 0, 0, 0.8) calc(var(--projects-reveal) + 4%),
			transparent var(--projects-reveal-edge)
		);
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		-webkit-mask-size: 100% 100%;
		mask-size: 100% 100%;
		contain: paint;
	}

	.z-space[data-active-panel="hero"] .z-panel--projects,
	.z-space[data-active-panel="projects"] .z-panel--hero {
		pointer-events: none;
	}

	.hero {
		--hero-vortex-offset: 1.1rem;
		--hero-headline-offset: 3.15rem;
		width: 100%;
		position: relative;
		height: 100%;
		min-height: 100%;
		padding: 0;
		overflow: hidden;
	}

	.z-panel.hero {
		height: 100%;
		min-height: 100%;
		padding: 0;
