---
import BaseHead from "../components/BaseHead.astro";
import ProjectsMonitor from "../components/ProjectsMonitor.astro";
import ScrollSpace3D from "../components/ScrollSpace3D.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";
import { ArrowRight, X } from "lucide";

const projects = (await getCollection("proyectos"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const currentYear = new Date().getFullYear();

const focusCards = [
	{
		index: "01",
		title: "Product Thinking",
		body: "Diseño soluciones para proyectos de gran envergadura con una mirada estratégica, visual y centrada en la experiencia.",
		tag: "PRODUCT SCOPE",
	},
	{
		index: "02",
		title: "UX/UI + Frontend",
		body: "Combino diseño UX/UI y front-end para convertir ideas en interfaces atractivas, funcionales y listas para producción.",
		tag: "BUILD SYSTEMS",
	},
	{
		index: "03",
		title: "Immersive Web",
		body: "Exploro experiencias 3D, VR, AR y WebAR para llevar la interacción web hacia formatos más expresivos e inmersivos.",
		tag: "R AND D MODE",
	},
];

const stackLines = [
	"> system.init()",
	"> importing capabilities...",
	"/ Product: UX/UI, Figma, Design Systems",
	"/ Frontend: Astro, React, TailwindCSS",
	"/ Web: HTML, CSS, JavaScript",
	"/ Exploration: 3D, VR, AR, WebAR",
	"> stack.status = 'READY'",
];

const stackTags = [
	"[ FIGMA ]",
	"[ ASTRO ]",
	"[ REACT ]",
	"[ TAILWIND ]",
	"[ HTML ]",
	"[ CSS ]",
	"[ JAVASCRIPT ]",
	"[ WEBAR ]",
];

const socialLinks = [
	{ label: "GitHub", href: "https://github.com/tavoavilaa" },
	{
		label: "LinkedIn",
		href: "https://www.linkedin.com/in/gustavo-avila-2a153311b/",
	},
	{ label: "Blog", href: "/blog" },
];

const heroArrowPaths = ArrowRight.map(([, attrs]) => attrs);
const xIconPaths = X.map(([, attrs]) => attrs);
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="portfolio-home">
		<div class="noise"></div>
			<div class="home-shell kinetic-grid">
				<aside class="side-rail" aria-label="Navegación secundaria">
					<a class="side-rail__brand" href="#inicio" aria-label="Ir al inicio">
						<img src="/Logo-G.jpg" alt="Logo Gustavo Avila" />
					</a>
					<nav class="side-rail__nav" aria-label="Redes sociales">
					<a
						href="https://www.linkedin.com/in/gustavo-avila-2a153311b/"
						target="_blank"
						rel="noreferrer"
						aria-label="LinkedIn"
					>
						<svg
							class="side-rail__icon side-rail__icon--brand"
							aria-hidden="true"
							viewBox="0 0 24 24"
						>
							<path
								fill="currentColor"
								d="M20.45 20.45h-3.56v-5.58c0-1.33-.02-3.03-1.85-3.03c-1.85 0-2.13 1.44-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85c3.61 0 4.28 2.38 4.28 5.48v6.26ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14a2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45Z"
							/>
						</svg>
					</a>
					<a
						href="https://github.com/tavoavilaa"
						target="_blank"
						rel="noreferrer"
						aria-label="GitHub"
					>
						<svg
							class="side-rail__icon side-rail__icon--brand"
							aria-hidden="true"
							viewBox="0 0 24 24"
						>
							<path
								fill="currentColor"
								d="M12 2C6.48 2 2 6.58 2 12.23c0 4.51 2.87 8.34 6.84 9.69c.5.1.68-.22.68-.48c0-.24-.01-1.04-.01-1.89c-2.78.62-3.37-1.21-3.37-1.21c-.45-1.18-1.11-1.49-1.11-1.49c-.91-.64.07-.63.07-.63c1 .08 1.53 1.05 1.53 1.05c.9 1.57 2.36 1.12 2.94.86c.09-.67.35-1.12.64-1.37c-2.22-.26-4.56-1.14-4.56-5.08c0-1.12.39-2.03 1.03-2.75c-.1-.26-.45-1.31.1-2.74c0 0 .84-.28 2.75 1.05A9.33 9.33 0 0 1 12 6.84a9.3 9.3 0 0 1 2.5.35c1.9-1.33 2.74-1.05 2.74-1.05c.56 1.43.21 2.48.11 2.74c.64.72 1.03 1.63 1.03 2.75c0 3.95-2.34 4.82-4.57 5.07c.36.32.69.95.69 1.92c0 1.39-.01 2.5-.01 2.84c0 .27.18.59.69.48A10.24 10.24 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z"
							/>
						</svg>
					</a>
					<a
						href="https://x.com/tavoavilaa"
						target="_blank"
						rel="noreferrer"
						aria-label="X"
					>
						<svg
							class="side-rail__icon"
							aria-hidden="true"
							viewBox="0 0 24 24"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
						>
							{
								xIconPaths.map((attrs) => (
									<path d={attrs.d} />
								))
							}
						</svg>
					</a>
				</nav>
			</aside>

			<div class="home-main">
				<header class="topbar">
					<div class="topbar__brand" aria-label="Gustavo Avila">
						<small class="topbar__brand-badge topbar__brand-name">Gustavo Avila</small>
					</div>

					<nav class="topbar__nav" aria-label="Principal">
						<a href="#proyectos">Proyectos</a>
						<a href="#stack">Stack</a>
						<a href="/about">Sobre mi</a>
						<a href="#contacto" class="topbar__cta">Contacto</a>
					</nav>
				</header>

				<main>
					<section id="inicio" class="z-space" data-z-space data-active-panel="hero">
						<span id="proyectos" class="z-space__anchor z-space__anchor--projects" aria-hidden="true"></span>
						<div class="z-space__viewport">
							<ScrollSpace3D />

							<section class="hero z-panel z-panel--hero" aria-label="Hero">
								<div class="hero__topline">
									<div class="hero__descriptor">
										<p>Creative Developer & UX Engineer</p>
										<p>AI Oriented · Building the 3D Web</p>
									</div>
								</div>

								<div class="hero__visual hero__visual--minimal" aria-hidden="true"></div>

								<div class="hero__headline">
									<h1 class="hero__name" aria-label="Design to development">
										<span>Design</span>
										<svg
											class="hero__name-arrow"
											aria-hidden="true"
											viewBox="0 0 24 24"
											fill="none"
											xmlns="http://www.w3.org/2000/svg"
										>
											{
												heroArrowPaths.map((attrs) => (
													<path d={attrs.d} />
												))
											}
										</svg>
										<span>Dev</span>
									</h1>
								</div>

								<div class="hero__footer">
									<p class="hero__caption">
										Cerrando la brecha entre<br />
										diseño y desarrollo
									</p>
									<p class="hero__caption hero__caption--end">Based in Bogotá, Co</p>
								</div>
							</section>

							<section class="section-block z-panel z-panel--projects" aria-label="Proyectos seleccionados">
								<ProjectsMonitor projects={projects} />
							</section>
						</div>
					</section>

					<section class="section-block section-block--alt">
						<div class="section-heading section-heading--stacked">
							<div>
								<h2>ENFOQUE ACTUAL</h2>
								<p>[ PRODUCTO, SISTEMAS, EXPERIENCIAS INMERSIVAS ]</p>
							</div>
						</div>

						<div class="focus-grid">
							{focusCards.map((item) => (
								<article class="focus-card">
									<span class="focus-card__index">{item.index}</span>
									<h3>{item.title}</h3>
									<p>{item.body}</p>
									<small>{item.tag}</small>
								</article>
							))}
						</div>
					</section>

					<section id="stack" class="section-block">
						<div class="section-heading section-heading--stacked">
							<div>
								<h2>STACK Y CAPACIDADES</h2>
								<p>[ TOOLS, FRONTEND, PRODUCT, IMMERSIVE WEB ]</p>
							</div>
						</div>

						<div class="stack-layout">
							<div class="terminal-card">
								<div class="terminal-card__header">TERMINAL OUTPUT</div>
								<div class="terminal-card__body">
									{stackLines.map((line) => <p>{line}</p>)}
								</div>
							</div>

							<div class="chip-grid">
								{stackTags.map((tag) => (
									<span class="terminal-chip">{tag}</span>
								))}
							</div>
						</div>
					</section>

					<section id="contacto" class="section-block section-block--contact">
						<div class="contact-copy">
							<p class="section-eyebrow">CONTACT INIT</p>
							<h2>HABLEMOS</h2>
							<p>
								Si has llegado hasta aquí, me encantaría recibir un mensaje
								con tu propuesta, idea o proyecto.
							</p>

							<div class="contact-links">
								{socialLinks.map((item) => (
									<a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
										{item.label}
									</a>
								))}
							</div>
						</div>

						<form
							class="contact-form"
							id="form"
							name="contact"
							action="/ty"
							method="POST"
							data-netlify="true"
							data-netlify-recaptcha="true"
						>
							<input type="hidden" name="form-name" value="contact" />
							<label>
								<span>Nombre</span>
								<input type="text" name="nombre" placeholder="Tu nombre" required />
							</label>

							<label>
								<span>Correo electrónico</span>
								<input
									type="email"
									name="correo"
									placeholder="correo@dominio.com"
									required
								/>
							</label>

							<label>
								<span>Mensaje</span>
								<textarea
									name="mensaje"
									rows="5"
									placeholder="Cuéntame qué estás construyendo."
									required
								></textarea>
							</label>

							<div data-netlify-recaptcha="true"></div>

							<button class="glow-button glow-button--full" type="submit">
								ENVIAR MENSAJE
							</button>
						</form>
					</section>
				</main>

				<footer class="page-footer">
						<p>{`©${currentYear} GUSTAVO AVILA · ALL RIGHTS RESERVED`}</p>
					<div>
						{socialLinks.map((item) => (
							<a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
								{item.label}
							</a>
						))}
					</div>
				</footer>
			</div>
		</div>
	</body>
</html>

<style is:global>
	.portfolio-home {
		background: #000;
		color: #bdc7d9;
		overflow-x: clip;
	}

	.kinetic-grid {
		background-image:
			linear-gradient(rgba(71, 223, 155, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(71, 223, 155, 0.04) 1px, transparent 1px);
		background-size: 72px 72px, 72px 72px;
		background-position: 0 0, 0 0;
	}

	.home-shell {
		position: relative;
		min-height: 100vh;
		overflow-x: clip;
	}

	.home-main {
		position: relative;
		margin-left: 80px;
	}

	.side-rail {
		position: fixed;
		inset: 0 auto 0 0;
		z-index: 30;
		display: flex;
		width: 80px;
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		border-right: 1px solid rgba(71, 223, 155, 0.12);
		background: rgba(0, 0, 0, 0.88);
		padding: 1.8rem 0 2rem;
		backdrop-filter: blur(14px);
	}

	.side-rail__brand {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.6rem;
		height: 2.6rem;
		text-decoration: none;
	}

	.side-rail__brand img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
	}

	.side-rail__nav {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.side-rail__nav a {
		display: grid;
		height: 2.5rem;
		width: 2.5rem;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 1rem;
		background: #000;
		color: rgba(255, 255, 255, 0.88);
		font-family: "Inter", sans-serif;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-decoration: none;
		box-shadow: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.side-rail__nav a svg {
		width: 1rem;
		height: 1rem;
		flex: none;
	}

	.side-rail__icon {
		stroke: currentColor;
		stroke-width: 1.9;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.side-rail__icon--brand {
		stroke: none;
	}

	.side-rail__nav a:hover {
		transform: translateY(-2px);
		border-color: rgba(255, 255, 255, 0.7);
		color: #ffffff;
		background: #000;
		box-shadow: 0 0 14px rgba(255, 255, 255, 0.08);
	}

	.topbar {
		position: sticky;
		top: 0;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem 2rem;
		border-bottom: 1px solid rgba(71, 223, 155, 0.08);
		background: rgba(0, 0, 0, 0.78);
		backdrop-filter: blur(16px);
	}

	.topbar__brand {
		display: inline-flex;
		flex-direction: column;
		gap: 0;
	}

	.topbar__brand span,
	.topbar__brand small {
		line-height: 1;
	}

	.topbar__brand-badge {
		display: inline-flex;
		align-items: center;
		font-family: "Inter", sans-serif;
		font-size: 1.9rem;
		color: #f4f7fb;
	}

	.topbar__brand-name {
		font-family: "Inter", sans-serif;
		font-size: 1.55rem;
		font-weight: 400;
		letter-spacing: 0;
		text-transform: none;
	}

	.topbar__nav {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.topbar__nav a,
	.page-footer a,
	.contact-links a {
		color: #bdc7d9;
		font-family: "Inter", sans-serif;
		font-size: 0.82rem;
		letter-spacing: 0.04em;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.topbar__nav a:hover,
	.page-footer a:hover,
	.contact-links a:hover {
		color: #47df9b;
	}

	.topbar__cta {
		position: relative;
		padding: 0.7em 2.1em;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 1rem;
		background: #000;
		box-shadow: none;
		color: rgba(255, 255, 255, 0.88) !important;
		font-weight: 700;
		letter-spacing: 0.06em !important;
		line-height: 1.4;
		transition:
			color 0.3s ease,
			box-shadow 0.3s ease,
			border-color 0.3s ease,
			background 0.3s ease,
			transform 180ms ease;
	}

	.topbar__cta:hover {
		color: #ffffff !important;
		border-color: rgba(255, 255, 255, 0.7);
		background: #000;
		box-shadow: 0 0 14px rgba(255, 255, 255, 0.08);
	}

	main {
		padding: 0 2rem 4rem;
	}

	.section-block,
	.page-footer {
		max-width: 1280px;
		margin: 0 auto;
	}

	.z-space {
		--hero-opacity: 1;
		--hero-y: 0vh;
		--hero-z: 0px;
		--hero-tilt: 0deg;
		--hero-scale: 1;
		--hero-headline-scroll-y: 0vh;
		--projects-opacity: 0;
		--projects-y: 18vh;
		--projects-z: -720px;
		--projects-tilt: -8deg;
		--projects-scale: 0.82;
		--projects-reveal: 0%;
		--projects-reveal-edge: 10%;
		--projects-reveal-x: 50%;
		--projects-reveal-y: 44%;
		position: relative;
		min-height: 320vh;
		margin: 0 auto;
	}

	.z-space__anchor {
		position: absolute;
		left: 0;
		width: 1px;
		height: 1px;
		pointer-events: none;
	}

	.z-space__anchor--projects {
		top: calc(105vh + 4rem);
	}

	.z-space__viewport {
		position: sticky;
		top: 82px;
		height: calc(100vh - 82px);
		min-height: 620px;
		overflow: hidden;
		perspective: 1200px;
		perspective-origin: 50% 50%;
		isolation: isolate;
	}

	.z-space__viewport::before,
	.z-space__viewport::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.z-space__viewport::before {
		background:
			linear-gradient(180deg, rgba(0, 0, 0, 0.68), transparent 18%, transparent 78%, rgba(0, 0, 0, 0.72));
	}

	.z-space__viewport::after {
		display: none;
	}

	.z-panel {
		position: absolute;
		inset: 0;
		z-index: 2;
		width: min(100%, 1280px);
		margin: auto;
		transform-style: preserve-3d;
		will-change: transform, opacity;
	}

	.z-panel--hero {
		opacity: var(--hero-opacity);
		transform:
			translate3d(0, var(--hero-y), var(--hero-z))
			rotateX(var(--hero-tilt))
			scale(var(--hero-scale));
	}

	.z-panel.z-panel--projects {
		display: flex;
		flex-direction: column;
		justify-content: center;
		max-width: 1280px;
		padding: clamp(1.5rem, 3vw, 2.6rem) 0;
		opacity: var(--projects-opacity);
		transform:
			translate3d(0, var(--projects-y), 0)
			scale(var(--projects-scale));
		-webkit-mask-image: radial-gradient(
			circle at var(--projects-reveal-x) var(--projects-reveal-y),
			#000 0 var(--projects-reveal),
			rgba(0, 0, 0, 0.8) calc(var(--projects-reveal) + 4%),
			transparent var(--projects-reveal-edge)
		);
		mask-image: radial-gradient(
			circle at var(--projects-reveal-x) var(--projects-reveal-y),
			#000 0 var(--projects-reveal),
			rgba(0, 0, 0, 0.8) calc(var(--projects-reveal) + 4%),
			transparent var(--projects-reveal-edge)
		);
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		-webkit-mask-size: 100% 100%;
		mask-size: 100% 100%;
		contain: paint;
	}

	.z-space[data-active-panel="hero"] .z-panel--projects,
	.z-space[data-active-panel="projects"] .z-panel--hero {
		pointer-events: none;
	}

	.z-panel--projects .section-heading {
		margin-bottom: clamp(1rem, 2vh, 1.5rem);
	}

	.hero {
		--hero-vortex-offset: 1.1rem;
		--hero-headline-offset: 3.15rem;
		width: 100%;
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr auto;
		gap: 1.5rem;
		min-height: calc(100vh - 110px);
		padding: 1.2rem 0 2rem;
		overflow: hidden;
	}

	.z-panel.hero {
		height: 100%;
		min-height: 100%;
		padding: clamp(1rem, 3vh, 2rem) 0 clamp(1.25rem, 4vh, 2.6rem);
	}

	.hero,
	.hero__visual,
	.hero__name {
		-webkit-user-select: none;
		user-select: none;
	}

	.section-heading p,
	.section-heading span,
	.project-card__content p,
	.terminal-card__header,
	.focus-card small,
	.page-footer p {
		font-family: "Inter", sans-serif;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.hero__topline {
		position: relative;
		z-index: 2;
		display: flex;
		align-items: flex-start;
		justify-content: flex-start;
		pointer-events: none;
	}

	.hero__descriptor {
		display: grid;
		gap: 0.12rem;
		max-width: 18rem;
	}

	.hero__descriptor p {
		margin: 0;
		font-size: 0.98rem;
		line-height: 1.2;
		color: #d9e3f6;
	}

	.hero__descriptor p:not(:first-child) {
		color: #7e8a97;
	}

	.hero__visual {
		position: absolute;
		inset: 2.6rem 0 7.8rem;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1;
		pointer-events: auto;
		transform: translateY(var(--hero-vortex-offset));
	}

	.hero__visual > * {
		position: relative;
		z-index: 1;
	}

	.hero__visual--minimal {
		padding: 0;
	}

	.hero__headline {
		position: absolute;
		inset: 2.6rem 0 7.8rem;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
