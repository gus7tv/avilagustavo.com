	.hero__scroll-hint {
		position: absolute;
		left: 50%;
		bottom: 2.15rem;
		z-index: 6;
		display: flex;
		width: 1.9rem;
		height: 3.15rem;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(126, 246, 196, 0.78);
		border-radius: 999px;
		background:
			linear-gradient(180deg, rgba(126, 246, 196, 0.08), transparent 62%),
			rgba(0, 0, 0, 0.14);
		box-shadow:
			0 0 0 1px rgba(237, 255, 247, 0.05) inset,
			0 0 16px rgba(71, 223, 155, 0.18),
			0 12px 30px rgba(0, 0, 0, 0.28);
		color: #edfff7;
		opacity: var(--scroll-hint-opacity);
		pointer-events: auto;
		text-decoration: none;
		transform: translateX(-50%);
		transition:
			border-color 180ms ease,
			opacity 220ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
		will-change: opacity, transform;
	}

	.hero__scroll-hint:hover {
		border-color: rgba(237, 255, 247, 0.86);
		box-shadow:
			0 0 0 1px rgba(237, 255, 247, 0.08) inset,
			0 0 22px rgba(71, 223, 155, 0.28),
