		font-weight: 500;
		line-height: 0.92;
		letter-spacing: 0;
		white-space: nowrap;
		color: var(--text-primary);
		opacity: var(--hero-seq-title-opacity);
		transform:
			translate3d(
				calc(var(--title-shift-x) * 1px),
				calc(var(--title-shift-y) * 1px),
				0
			)
			rotate(calc(var(--title-tilt) * 1deg));
		text-shadow:
			0 0 calc(10px + var(--title-glow) * 5px) rgba(255, 255, 255, calc(0.03 + var(--title-glow) * 0.03)),
			0 0 calc(18px + var(--title-glow) * 12px) rgba(120, 255, 196, calc(0.02 + var(--title-glow) * 0.035));
		transition:
			transform 260ms ease-out,
			text-shadow 320ms ease-out,
			opacity 200ms linear;
		will-change: transform, text-shadow, opacity;
		pointer-events: none;
