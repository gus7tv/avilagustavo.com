---
import BaseHead from "../components/BaseHead.astro";
import HeroParticles from "../components/HeroParticles.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";

const projects = (await getCollection("proyectos"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const currentYear = new Date().getFullYear();

const focusCards = [
	{
		index: "01",
		title: "Product_Thinking",
		body: "Diseño soluciones para proyectos de gran envergadura con una mirada estratégica, visual y centrada en la experiencia.",
		tag: "PRODUCT_SCOPE",
	},
	{
		index: "02",
		title: "UX_UI + Frontend",
		body: "Combino diseño UX/UI y front-end para convertir ideas en interfaces atractivas, funcionales y listas para producción.",
		tag: "BUILD_SYSTEMS",
	},
	{
		index: "03",
		title: "Immersive_Web",
		body: "Exploro experiencias 3D, VR, AR y WebAR para llevar la interacción web hacia formatos más expresivos e inmersivos.",
		tag: "R_AND_D_MODE",
	},
];

const stackLines = [
	"> system.init()",
	"> importing capabilities...",
	"/ Product: UX/UI, Figma, Design Systems",
	"/ Frontend: Astro, React, TailwindCSS",
	"/ Web: HTML, CSS, JavaScript",
	"/ Exploration: 3D, VR, AR, WebAR",
	"> stack.status = 'READY'",
];

const stackTags = [
	"[ FIGMA ]",
	"[ ASTRO ]",
	"[ REACT ]",
	"[ TAILWIND ]",
	"[ HTML ]",
	"[ CSS ]",
	"[ JAVASCRIPT ]",
	"[ WEBAR ]",
];

const socialLinks = [
	{ label: "GitHub", href: "https://github.com/tavoavilaa" },
	{
		label: "LinkedIn",
		href: "https://www.linkedin.com/in/gustavo-avila-2a153311b/",
	},
	{ label: "Blog", href: "/blog" },
];
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="portfolio-home">
		<div class="noise"></div>
		<div class="home-shell kinetic-grid">
			<aside class="side-rail" aria-label="Navegación secundaria">
				<a class="side-rail__brand" href="#inicio">[ga.]</a>
				<nav class="side-rail__nav">
					<a href="#inicio">IN</a>
					<a href="#proyectos">PR</a>
					<a href="#stack">ST</a>
					<a href="#contacto">CT</a>
				</nav>
			</aside>

			<div class="home-main">
				<header class="topbar">
					<a class="topbar__brand" href="#inicio">
						<span>Gustavo Avila</span>
						<small>Designer + Frontend Developer</small>
					</a>

					<nav class="topbar__nav" aria-label="Principal">
						<a href="#proyectos">// PROYECTOS</a>
						<a href="#stack">// STACK</a>
						<a href="/about">// SOBRE_MI</a>
						<a href="#contacto" class="topbar__cta">CONTACTO</a>
					</nav>
				</header>

				<main>
					<section id="inicio" class="hero">
						<div class="hero__topline">
							<div class="hero__descriptor">
								<p>Product & Experience Designer</p>
								<p>Design Systems · UX</p>
								<p>Frontend · Motion · WebGL</p>
							</div>
						</div>

						<div class="hero__visual hero__visual--minimal">
							<HeroParticles />
						</div>

						<div class="hero__footer">
							<p class="hero__caption">
								Diseño y desarrollo web con foco en claridad y sistemas.
							</p>
							<h1 class="hero__name">Gustavo Avila</h1>
							<p class="hero__caption hero__caption--end">Portfolio 2026</p>
						</div>
					</section>

					<section id="proyectos" class="section-block">
						<div class="section-heading">
							<div>
								<h2>PROYECTOS_SELECCIONADOS</h2>
								<p>[ LANDINGS, WEBAPPS, UX/UI, FRONTEND ]</p>
							</div>
							<span>SCROLL_TO_DISCOVER_01-04</span>
						</div>

						<div class="projects-grid">
							{projects.map((project, index) => (
								<a
									class="project-card"
									href={project.data.url}
									target="_blank"
									rel="noreferrer"
								>
									<img
										src={project.data.heroImage}
										alt={project.data.title}
										loading="lazy"
									/>
									<div class="project-card__overlay"></div>
									<div class="project-card__content">
										<p>{`// PROYECTO_0${index + 1} · ${project.data.category.toUpperCase()}`}</p>
										<h3>{project.data.title}</h3>
										<span>{project.data.description}</span>
									</div>
								</a>
							))}
						</div>
					</section>

					<section class="section-block section-block--alt">
						<div class="section-heading section-heading--stacked">
							<div>
								<h2>ENFOQUE_ACTUAL</h2>
								<p>[ PRODUCTO, SISTEMAS, EXPERIENCIAS INMERSIVAS ]</p>
							</div>
						</div>

						<div class="focus-grid">
							{focusCards.map((item) => (
								<article class="focus-card">
									<span class="focus-card__index">{item.index}</span>
									<h3>{item.title}</h3>
									<p>{item.body}</p>
									<small>{item.tag}</small>
								</article>
							))}
						</div>
					</section>

					<section id="stack" class="section-block">
						<div class="section-heading section-heading--stacked">
							<div>
								<h2>STACK_Y_CAPACIDADES</h2>
								<p>[ TOOLS, FRONTEND, PRODUCT, IMMERSIVE WEB ]</p>
							</div>
						</div>

						<div class="stack-layout">
							<div class="terminal-card">
								<div class="terminal-card__header">TERMINAL_OUTPUT</div>
								<div class="terminal-card__body">
									{stackLines.map((line) => <p>{line}</p>)}
								</div>
							</div>

							<div class="chip-grid">
								{stackTags.map((tag) => (
									<span class="terminal-chip">{tag}</span>
								))}
							</div>
						</div>
					</section>

					<section id="contacto" class="section-block section-block--contact">
						<div class="contact-copy">
							<p class="section-eyebrow">// CONTACT_INIT</p>
							<h2>HABLEMOS</h2>
							<p>
								Si has llegado hasta aquí, me encantaría recibir un mensaje
								con tu propuesta, idea o proyecto.
							</p>

							<div class="contact-links">
								{socialLinks.map((item) => (
									<a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
										{item.label}
									</a>
								))}
							</div>
						</div>

						<form
							class="contact-form"
							id="form"
							name="contact"
							action="/ty"
							method="POST"
							data-netlify="true"
							data-netlify-recaptcha="true"
						>
							<input type="hidden" name="form-name" value="contact" />
							<label>
								<span>Nombre</span>
								<input type="text" name="nombre" placeholder="Tu nombre" required />
							</label>

							<label>
								<span>Correo electrónico</span>
								<input
									type="email"
									name="correo"
									placeholder="correo@dominio.com"
									required
								/>
							</label>

							<label>
								<span>Mensaje</span>
								<textarea
									name="mensaje"
									rows="5"
									placeholder="Cuéntame qué estás construyendo."
									required
								></textarea>
							</label>

							<div data-netlify-recaptcha="true"></div>

							<button class="glow-button glow-button--full" type="submit">
								ENVIAR_MENSAJE
							</button>
						</form>
					</section>
				</main>

				<footer class="page-footer">
					<p>{`©${currentYear} GUSTAVO_AVILA // ALL_RIGHTS_RESERVED`}</p>
					<div>
						{socialLinks.map((item) => (
							<a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
								{item.label}
							</a>
						))}
					</div>
				</footer>
			</div>
		</div>
	</body>
</html>

<style is:global>
	.portfolio-home {
		background:
			radial-gradient(circle at top right, rgba(71, 223, 155, 0.08), transparent 28%),
			#000;
		color: #bdc7d9;
	}

	.kinetic-grid {
		background-image:
			linear-gradient(rgba(71, 223, 155, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(71, 223, 155, 0.04) 1px, transparent 1px);
		background-size: 72px 72px;
	}

	.home-shell {
		position: relative;
		min-height: 100vh;
	}

	.home-main {
		margin-left: 80px;
	}

	.side-rail {
		position: fixed;
		inset: 0 auto 0 0;
		z-index: 30;
		display: flex;
		width: 80px;
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		border-right: 1px solid rgba(71, 223, 155, 0.12);
		background: rgba(0, 0, 0, 0.88);
		padding: 1.8rem 0 2rem;
		backdrop-filter: blur(14px);
	}

	.side-rail__brand {
		font-family: "Space Grotesk", sans-serif;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: -0.05em;
		color: #47df9b;
		text-decoration: none;
	}

	.side-rail__nav {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.side-rail__nav a {
		display: grid;
		height: 2.5rem;
		width: 2.5rem;
		place-items: center;
		border: 1px solid rgba(71, 223, 155, 0.12);
		border-radius: 0.9rem;
		background: rgba(71, 223, 155, 0.04);
		color: #bbcabe;
		font-family: "Space Grotesk", sans-serif;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-decoration: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			color 180ms ease;
	}

	.side-rail__nav a:hover {
		transform: translateY(-2px);
		border-color: rgba(71, 223, 155, 0.34);
		color: #47df9b;
	}

	.topbar {
		position: sticky;
		top: 0;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem 2rem;
		border-bottom: 1px solid rgba(71, 223, 155, 0.08);
		background: rgba(0, 0, 0, 0.78);
		backdrop-filter: blur(16px);
	}

	.topbar__brand {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		text-decoration: none;
	}

	.topbar__brand span,
	.topbar__brand small {
		line-height: 1.2;
	}

	.topbar__brand span {
		font-family: "Space Grotesk", sans-serif;
		font-size: 1.1rem;
		font-weight: 700;
		color: #d9e3f6;
	}

	.topbar__brand small {
		color: #47df9b;
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.topbar__nav {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.topbar__nav a,
	.page-footer a,
	.contact-links a {
		color: #bdc7d9;
		font-family: "Space Grotesk", sans-serif;
		font-size: 0.76rem;
		letter-spacing: 0.12em;
		text-decoration: none;
		text-transform: uppercase;
		transition: color 180ms ease;
	}

	.topbar__nav a:hover,
	.page-footer a:hover,
	.contact-links a:hover {
		color: #47df9b;
	}

	.topbar__cta {
		padding: 0.8rem 1.1rem;
		border-radius: 0.8rem;
		background: linear-gradient(135deg, rgba(71, 223, 155, 1), rgba(71, 223, 155, 0.82));
		box-shadow: 0 0 24px rgba(71, 223, 155, 0.22);
		color: #003822 !important;
		font-weight: 700;
	}

	main {
		padding: 0 2rem 4rem;
	}

	.hero,
	.section-block,
	.page-footer {
		max-width: 1280px;
		margin: 0 auto;
	}

	.hero {
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr auto;
		gap: 1.5rem;
		min-height: calc(100vh - 110px);
		padding: 1.2rem 0 2rem;
		overflow: hidden;
	}

	.hero,
	.hero__visual,
	.hero__name {
		-webkit-user-select: none;
		user-select: none;
	}

	.section-heading p,
	.section-heading span,
	.project-card__content p,
	.terminal-card__header,
	.focus-card small,
	.page-footer p {
		font-family: "Space Grotesk", sans-serif;
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.hero__topline {
		position: relative;
		z-index: 2;
		display: flex;
		align-items: flex-start;
		justify-content: flex-start;
		pointer-events: none;
	}

	.hero__descriptor {
		display: grid;
		gap: 0.12rem;
		max-width: 18rem;
	}

	.hero__descriptor p {
		margin: 0;
		font-size: 0.98rem;
		line-height: 1.2;
		color: #d9e3f6;
	}

	.hero__descriptor p:not(:first-child) {
		color: #7e8a97;
	}

	.hero__visual {
		position: absolute;
		inset: 2.6rem 0 7.8rem;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1;
		pointer-events: auto;
	}

	.hero__visual--minimal {
		padding: 0;
	}

	.hero__footer {
		position: relative;
		z-index: 2;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: end;
		gap: 1rem;
		pointer-events: none;
	}

	.hero__caption {
		margin: 0;
		color: #d9e3f6;
		font-size: 0.98rem;
		line-height: 1.2;
		max-width: 19rem;
	}

	.hero__caption--end {
		justify-self: end;
		text-align: right;
		color: #aeb8c7;
	}

	.hero__name {
		margin: 0;
		font-family: "Space Grotesk", sans-serif;
		font-size: clamp(4rem, 10vw, 6.9rem);
		font-weight: 500;
		line-height: 0.92;
		letter-spacing: -0.09em;
		color: #f4f7fb;
		pointer-events: none;
	}

	.glow-button,
	.ghost-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1rem 1.35rem;
		border-radius: 0.9rem;
		font-family: "Space Grotesk", sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background 180ms ease,
			border-color 180ms ease;
	}

	.glow-button {
		background: linear-gradient(135deg, rgba(71, 223, 155, 1), rgba(71, 223, 155, 0.82));
		box-shadow:
			0 0 30px rgba(71, 223, 155, 0.22),
			inset 0 1px 0 rgba(255, 255, 255, 0.16);
		color: #003822;
		border: none;
	}

	.ghost-button {
		border: 1px solid rgba(71, 223, 155, 0.16);
		background: rgba(0, 0, 0, 0.64);
		color: #d9e3f6;
		backdrop-filter: blur(20px);
	}

	.glow-button:hover,
	.ghost-button:hover {
		transform: translateY(-2px);
	}

	.glow-button:hover {
		box-shadow:
			0 0 42px rgba(71, 223, 155, 0.32),
			inset 0 1px 0 rgba(255, 255, 255, 0.22);
	}

	.ghost-button:hover {
		border-color: rgba(71, 223, 155, 0.32);
		background: rgba(0, 0, 0, 0.88);
	}

	.glow-button--full {
		width: 100%;
		cursor: pointer;
	}

	.focus-card,
	.terminal-card,
	.contact-form,
	.contact-copy {
		border: 1px solid rgba(71, 223, 155, 0.1);
		border-radius: 1.5rem;
		background: rgba(0, 0, 0, 0.62);
		backdrop-filter: blur(20px);
	}

	.focus-card p,
	.contact-copy p {
		margin: 0;
		color: #bbcabe;
	}

	.section-block {
		padding: 5.5rem 0 0;
	}

	.section-block--alt {
		padding-top: 6rem;
	}

	.section-heading {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
		padding-bottom: 1.35rem;
		border-bottom: 1px solid rgba(71, 223, 155, 0.1);
	}

	.section-heading--stacked {
		align-items: flex-start;
		justify-content: flex-start;
	}

	.section-heading h2,
	.contact-copy h2 {
		margin: 0;
		font-family: "Space Grotesk", sans-serif;
		font-size: clamp(2.25rem, 4vw, 3.8rem);
		font-weight: 700;
		letter-spacing: -0.06em;
		color: #d9e3f6;
	}

	.section-heading p {
		margin: 0.75rem 0 0;
		color: #47df9b;
	}

	.section-heading span {
		color: #bbcabe;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1px;
		overflow: hidden;
		border-radius: 1.8rem;
		background: rgba(71, 223, 155, 0.12);
		padding: 1px;
	}

	.project-card {
		position: relative;
		overflow: hidden;
		min-height: 23rem;
		background: #000;
		text-decoration: none;
	}

	.project-card img,
	.project-card__overlay {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.project-card img {
		object-fit: cover;
		opacity: 0.56;
		transition:
			transform 280ms ease,
			opacity 280ms ease;
	}

	.project-card__overlay {
		background:
			linear-gradient(180deg, rgba(0, 0, 0, 0) 10%, rgba(0, 0, 0, 0.9) 100%),
			linear-gradient(90deg, rgba(0, 0, 0, 0.28), rgba(0, 0, 0, 0));
	}

	.project-card__content {
		position: absolute;
		right: 1.7rem;
		bottom: 1.5rem;
		left: 1.7rem;
		z-index: 1;
	}

	.project-card__content p,
	.focus-card small {
		margin: 0 0 0.7rem;
		color: #47df9b;
	}

	.project-card__content h3,
	.focus-card h3 {
		margin: 0 0 0.75rem;
		font-family: "Space Grotesk", sans-serif;
		font-size: 1.6rem;
		font-weight: 700;
		letter-spacing: -0.05em;
		color: #d9e3f6;
	}

	.project-card__content span {
		display: block;
		color: #bbcabe;
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.project-card:hover img {
		transform: scale(1.04);
		opacity: 0.7;
	}

	.focus-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.4rem;
	}

	.focus-card {
		padding: 1.8rem;
	}

	.focus-card__index {
		display: block;
		margin-bottom: 1rem;
		font-family: "Space Grotesk", sans-serif;
		font-size: 3rem;
		font-weight: 700;
		line-height: 1;
		color: rgba(71, 223, 155, 0.14);
	}

	.focus-card small {
		display: block;
		margin-top: 1.25rem;
	}

	.stack-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
		gap: 1.4rem;
		align-items: center;
	}

	.terminal-card,
	.contact-form,
	.contact-copy {
		padding: 1.7rem;
	}

	.terminal-card__header {
		margin-bottom: 1rem;
		color: #47df9b;
	}

	.terminal-card__body p {
		margin: 0 0 0.55rem;
		font-size: 0.92rem;
		line-height: 1.75;
		color: #bbcabe;
	}

	.terminal-card__body p:first-child,
	.terminal-card__body p:nth-child(2),
	.terminal-card__body p:last-child {
		color: #47df9b;
	}

	.chip-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.terminal-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 4rem;
		padding: 0.9rem 1rem;
		border: 1px solid rgba(71, 223, 155, 0.14);
		border-radius: 1.2rem;
		background: rgba(0, 0, 0, 0.54);
		color: #47df9b;
		font-family: "Space Grotesk", sans-serif;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-align: center;
	}

	.section-block--contact {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
		gap: 1.4rem;
		align-items: start;
	}

	.contact-copy {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.contact-links {
		display: flex;
