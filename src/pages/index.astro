	.hero__name {
		margin: 0;
		--title-shift-x: 0;
		--title-shift-y: 0;
		--title-tilt: 0;
		--title-glow: 0;
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.22em;
		width: 100%;
