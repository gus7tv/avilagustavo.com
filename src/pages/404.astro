---
import BaseHead from "../components/BaseHead.astro";
import MessageHero from "../components/MessageHero.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={`Page not found | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="message-page">
		<div class="noise"></div>
		<main>
			<MessageHero
				title="404"
				kicker="PAGE NOT FOUND"
				message="The page you're looking for doesn't exist or has been moved."
				ctaLabel="BACK TO HOME"
				ctaHref="/"
			/>
		</main>
	</body>
</html>

<style>
	.message-page {
		min-height: 100svh;
		overflow: hidden;
		background: #000;
		color: var(--text-secondary);
	}

	.message-page::before {
		content: "";
		position: fixed;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(71, 223, 155, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(71, 223, 155, 0.04) 1px, transparent 1px);
		background-size: 72px 72px, 72px 72px;
	}
</style>
