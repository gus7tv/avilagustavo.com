<div class="scroll-space-scene" data-scroll-space-scene aria-hidden="true"></div>

<script type="module" is:inline>
	import * as THREE from 'https://esm.sh/three@0.161.0';

	const containers = document.querySelectorAll('[data-scroll-space-scene]');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
	const lerp = (start, end, progress) => start + (end - start) * progress;
	const smoothstep = (edge0, edge1, value) => {
		const t = clamp((value - edge0) / (edge1 - edge0), 0, 1);
		return t * t * (3 - 2 * t);
	};
	const HERO_GUI_ENABLED_KEY = 'gavila:hero-gui-enabled';
	const HERO_GUI_TUNING_KEY = 'gavila:hero-tuning-v1';

	const safeStorage = {
		get(key) {
			try {
				return window.localStorage.getItem(key);
			} catch {
				return null;
			}
		},
		set(key, value) {
			try {
				window.localStorage.setItem(key, value);
			} catch {
				// Debug-only persistence should never block the hero.
			}
		},
		remove(key) {
			try {
				window.localStorage.removeItem(key);
			} catch {
				// Debug-only persistence should never block the hero.
			}
		},
	};

	function shouldEnableHeroGui() {
		const params = new URLSearchParams(window.location.search);
		const isLocalPreview = ['localhost', '127.0.0.1', '::1'].includes(window.location.hostname);

		return (
			isLocalPreview ||
			params.has('heroGui') ||
			params.get('gui') === 'hero' ||
			safeStorage.get(HERO_GUI_ENABLED_KEY) === 'true'
		);
	}

	function makeTuningDefaults(isMobile) {
		return {
			vortexX: 6.62,
			vortexY: 2.64,
			revealX: 50,
			revealY: 44,
			scrollStart: 0.46,
			scrollEnd: 0.95,
			headlineBaseRem: 3.15,
			headlineScrollVh: 14,
			particleSize: 0.351,
			particleToneMix: 1,
			vortexOpenStart: 0.284,
			vortexOpenEnd: 0.45,
			coreFinal: 11.5,
			innerPush: 14,
			latePush: 6.5,
			depthPush: 0,
			stretchStart: 0.393,
			stretchPeak: 0.75,
			streakBaseLength: 0.54,
			streakMaxLength: 3,
			stretchFadeStart: 0.43,
			stretchFadeEnd: 1,
			particleFadeStart: 0.62,
			particleFadeEnd: 0.69,
			projectRevealStart: 0.536,
			projectRevealEnd: 0.852,
			projectRevealMax: 140,
			projectRevealFeather: 20.8,
			heroExitStart: 0.346,
			heroExitEnd: 0.67,
			projectsEnterStart: 0.52,
			projectsEnterEnd: 0.78,
			postprocessingEnabled: true,
			bloomStrength: 0.97,
			bloomRadius: 0,
			bloomThreshold: 0.13,
			chromaAmount: 0.0004,
			chromaStart: 0,
			chromaPeak: 0.1,
			chromaFadeStart: 0.3,
			chromaFadeEnd: 0.76,
			lenisEnabled: true,
			lenisLerp: 0.17,
			lenisWheelMultiplier: 0.596,
		};
	}

	function snapshotTuning(tuning) {
		return Object.fromEntries(
			Object.entries(tuning).filter(([, value]) => typeof value === 'number' || typeof value === 'boolean'),
		);
	}

	function getInitialTuning(isMobile, useStoredTuning) {
		const defaults = makeTuningDefaults(isMobile);
		if (!useStoredTuning) return defaults;

		try {
			const stored = JSON.parse(safeStorage.get(HERO_GUI_TUNING_KEY) ?? '{}');
			return { ...defaults, ...stored };
		} catch {
			return defaults;
		}
	}

	function saveHeroTuning(tuning) {
		safeStorage.set(HERO_GUI_TUNING_KEY, JSON.stringify(snapshotTuning(tuning)));
	}

	const ChromaticAberrationShader = {
		uniforms: {
			tDiffuse: { value: null },
			uAmount: { value: 0 },
		},
		vertexShader: `
			varying vec2 vUv;

			void main() {
				vUv = uv;
				gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
			}
		`,
		fragmentShader: `
			uniform sampler2D tDiffuse;
			uniform float uAmount;
			varying vec2 vUv;

			void main() {
				vec2 direction = vUv - vec2(0.5);
				float distanceFromCenter = length(direction);
				vec2 offset = direction * uAmount * distanceFromCenter;
				float red = texture2D(tDiffuse, vUv - offset).r;
				float green = texture2D(tDiffuse, vUv).g;
				float blue = texture2D(tDiffuse, vUv + offset).b;
				float alpha = texture2D(tDiffuse, vUv).a;
				gl_FragColor = vec4(red, green, blue, alpha);
			}
		`,
	};

	function makeParticleSprite() {
		const canvas = document.createElement('canvas');
		canvas.width = 128;
		canvas.height = 128;

		const context = canvas.getContext('2d');
		if (!context) return null;

		const gradient = context.createRadialGradient(64, 64, 2, 64, 64, 64);
		gradient.addColorStop(0, 'rgba(238, 255, 248, 1)');
		gradient.addColorStop(0.16, 'rgba(120, 255, 196, 0.95)');
		gradient.addColorStop(0.46, 'rgba(71, 223, 155, 0.32)');
		gradient.addColorStop(1, 'rgba(71, 223, 155, 0)');
		context.fillStyle = gradient;
		context.fillRect(0, 0, 128, 128);

		return new THREE.CanvasTexture(canvas);
	}

	function buildStreakMaterial() {
		return new THREE.ShaderMaterial({
			uniforms: {
				uOpacity: { value: 0.72 },
			},
			vertexShader: `
				attribute vec3 color;
				attribute float alpha;
				varying vec3 vColor;
				varying float vAlpha;

				void main() {
					vColor = color;
					vAlpha = alpha;
					gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
				}
			`,
			fragmentShader: `
				uniform float uOpacity;
				varying vec3 vColor;
				varying float vAlpha;

				void main() {
					gl_FragColor = vec4(vColor, vAlpha * uOpacity);
				}
			`,
			transparent: true,
			blending: THREE.AdditiveBlending,
			depthWrite: false,
		});
	}

	async function mountScrollSpace(container) {
		if (container.dataset.ready === 'true') return;
		container.dataset.ready = 'true';

		const stage = container.closest('[data-z-space]');
		if (!stage) return;

		const isMobile = window.innerWidth < 768;
		const pixelRatioCap = isMobile ? 1.2 : 1.55;
		const scene = new THREE.Scene();
		scene.fog = new THREE.FogExp2(0x000000, 0.018);

		const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 160);
		camera.position.set(0, 0, 18);

		const renderer = new THREE.WebGLRenderer({
			alpha: true,
			antialias: !isMobile,
			powerPreference: 'high-performance',
		});
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, pixelRatioCap));
		renderer.setClearColor(0x000000, 0);
		container.appendChild(renderer.domElement);

		const heroGuiEnabled = shouldEnableHeroGui();
		const tuning = getInitialTuning(isMobile, heroGuiEnabled);
		let composer = null;
		let bloomPass = null;
		let chromaPass = null;
		let postprocessingImportPromise = null;
		let gui = null;

		const ensurePostprocessing = async () => {
			if (composer || prefersReducedMotion) return;
			postprocessingImportPromise ??= Promise.all([
				import('https://esm.sh/three@0.161.0/examples/jsm/postprocessing/EffectComposer.js'),
				import('https://esm.sh/three@0.161.0/examples/jsm/postprocessing/RenderPass.js'),
				import('https://esm.sh/three@0.161.0/examples/jsm/postprocessing/ShaderPass.js'),
				import('https://esm.sh/three@0.161.0/examples/jsm/postprocessing/UnrealBloomPass.js'),
			]);

			const [{ EffectComposer }, { RenderPass }, { ShaderPass }, { UnrealBloomPass }] = await postprocessingImportPromise;
			if (composer) return;

			composer = new EffectComposer(renderer);
			composer.setPixelRatio?.(Math.min(window.devicePixelRatio, isMobile ? 1 : 1.35));
			const renderPass = new RenderPass(scene, camera);
			const width = Math.max(1, container.clientWidth);
			const height = Math.max(1, container.clientHeight);
			bloomPass = new UnrealBloomPass(
				new THREE.Vector2(width, height),
				tuning.bloomStrength,
				tuning.bloomRadius,
				tuning.bloomThreshold,
			);
			chromaPass = new ShaderPass(ChromaticAberrationShader);
			chromaPass.enabled = false;
			composer.addPass(renderPass);
			composer.addPass(bloomPass);
			composer.addPass(chromaPass);
			composer.setSize(width, height);
		};

		if (tuning.postprocessingEnabled && !prefersReducedMotion) {
			await ensurePostprocessing();
		}
		const particleSprite = makeParticleSprite();
		const particleCount = isMobile ? 1500 : 3600;
		const positions = new Float32Array(particleCount * 3);
		const colors = new Float32Array(particleCount * 3);
		const streakPositions = new Float32Array(particleCount * 2 * 3);
		const streakColors = new Float32Array(particleCount * 2 * 3);
		const streakAlpha = new Float32Array(particleCount * 2);
		const particleAngles = new Float32Array(particleCount);
		const particleRadius = new Float32Array(particleCount);
		const particleDepth = new Float32Array(particleCount);
		const particleOffsets = new Float32Array(particleCount);
		const particleSeeds = new Float32Array(particleCount);
		const zStart = 24;
		const zEnd = -92;
		const baseCoreRadius = isMobile ? 2.4 : 3.2;

		for (let index = 0; index < particleCount; index += 1) {
			const dataIndex = index * 3;
			const streakIndex = index * 6;
			const alphaIndex = index * 2;
			const angle = Math.random() * Math.PI * 2;
			const depth = lerp(zStart, zEnd, Math.random());
			const radius = lerp(1.1, isMobile ? 9.8 : 13.2, Math.pow(Math.random(), 0.62));

			particleAngles[index] = angle;
			particleRadius[index] = radius;
			particleDepth[index] = depth;
			particleOffsets[index] = Math.random() * Math.PI * 2;
			particleSeeds[index] = Math.random();

			positions[dataIndex] = Math.cos(angle) * (baseCoreRadius + radius);
			positions[dataIndex + 1] = Math.sin(angle) * (baseCoreRadius + radius) * 0.64;
			positions[dataIndex + 2] = depth;
			colors[dataIndex] = 0.24;
			colors[dataIndex + 1] = 0.92;
			colors[dataIndex + 2] = 0.66;

			streakPositions[streakIndex] = positions[dataIndex];
			streakPositions[streakIndex + 1] = positions[dataIndex + 1];
			streakPositions[streakIndex + 2] = depth;
			streakPositions[streakIndex + 3] = positions[dataIndex];
			streakPositions[streakIndex + 4] = positions[dataIndex + 1];
			streakPositions[streakIndex + 5] = depth;
			streakColors[streakIndex] = 0.1;
			streakColors[streakIndex + 1] = 0.58;
			streakColors[streakIndex + 2] = 0.42;
			streakColors[streakIndex + 3] = 0.42;
			streakColors[streakIndex + 4] = 1;
			streakColors[streakIndex + 5] = 0.78;
			streakAlpha[alphaIndex] = 0;
			streakAlpha[alphaIndex + 1] = 0.46;
		}

		const particleGeometry = new THREE.BufferGeometry();
		particleGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
		particleGeometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
		const streakGeometry = new THREE.BufferGeometry();
		streakGeometry.setAttribute('position', new THREE.BufferAttribute(streakPositions, 3));
		streakGeometry.setAttribute('color', new THREE.BufferAttribute(streakColors, 3));
		streakGeometry.setAttribute('alpha', new THREE.BufferAttribute(streakAlpha, 1));

		const particleMaterial = new THREE.PointsMaterial({
			color: 0xedfff7,
			size: isMobile ? 0.17 : 0.22,
			transparent: true,
			opacity: 1,
			map: particleSprite,
			vertexColors: true,
			blending: THREE.AdditiveBlending,
			depthWrite: false,
			sizeAttenuation: true,
		});
		particleMaterial.toneMapped = false;
		particleMaterial.size = tuning.particleSize;

		const particleCloud = new THREE.Points(particleGeometry, particleMaterial);
		particleCloud.rotation.set(-0.06, 0.04, -0.025);
		particleCloud.position.x = tuning.vortexX;
		particleCloud.position.y = tuning.vortexY;
		const streakMaterial = buildStreakMaterial();
		const streakCloud = new THREE.LineSegments(streakGeometry, streakMaterial);
		streakCloud.rotation.copy(particleCloud.rotation);
		streakCloud.position.x = tuning.vortexX;
		streakCloud.position.y = tuning.vortexY;
		scene.add(streakCloud);
		scene.add(particleCloud);

		const pointer = { x: 0, y: 0 };
		const pointerTarget = { x: 0, y: 0 };
		const state = { progress: 0, targetProgress: 0, rawProgress: 0 };
		let frameId = 0;
		let isSceneVisible = true;
		let visibilityObserver = null;
		let lenis = null;
		let lenisRafId = 0;
		let lenisSetupToken = 0;
		let lenisImportPromise = null;

		const updatePanelVars = (progress) => {
			const vortexOpen = smoothstep(tuning.vortexOpenStart, tuning.vortexOpenEnd, progress);
			const heroExit = smoothstep(tuning.heroExitStart, tuning.heroExitEnd, progress);
			const projectsEnter = smoothstep(tuning.projectsEnterStart, tuning.projectsEnterEnd, progress);
			const heroOpacity = 1 - smoothstep(0.56, 0.76, progress);
			const projectsOpacity = smoothstep(0.58, 0.78, progress);
			const projectsProgress = smoothstep(0.74, 1, progress);
			const projectsReveal = lerp(0, tuning.projectRevealMax, smoothstep(tuning.projectRevealStart, tuning.projectRevealEnd, progress));
			const projectsRevealEdge = Math.min(170, projectsReveal + tuning.projectRevealFeather);

			stage.style.setProperty('--hero-opacity', heroOpacity.toFixed(3));
			stage.style.setProperty('--hero-y', `${lerp(0, -14, heroExit).toFixed(3)}vh`);
			stage.style.setProperty('--hero-z', `${lerp(0, -640, heroExit).toFixed(3)}px`);
			stage.style.setProperty('--hero-tilt', `${lerp(0, 7, heroExit).toFixed(3)}deg`);
			stage.style.setProperty('--hero-scale', lerp(1, 0.86, heroExit).toFixed(3));
			stage.style.setProperty('--hero-headline-offset', `${tuning.headlineBaseRem.toFixed(3)}rem`);
			stage.style.setProperty('--hero-headline-scroll-y', `${lerp(0, tuning.headlineScrollVh, vortexOpen).toFixed(3)}vh`);
			stage.style.setProperty('--projects-opacity', projectsOpacity.toFixed(3));
			stage.style.setProperty('--projects-y', `${lerp(18, 0, projectsEnter).toFixed(3)}vh`);
			stage.style.setProperty('--projects-z', `${lerp(-720, 0, projectsEnter).toFixed(3)}px`);
			stage.style.setProperty('--projects-tilt', `${lerp(-8, 0, projectsEnter).toFixed(3)}deg`);
			stage.style.setProperty('--projects-scale', lerp(0.82, 1, projectsEnter).toFixed(3));
			stage.style.setProperty('--projects-progress', projectsProgress.toFixed(4));
			stage.style.setProperty('--z-progress', progress.toFixed(4));
			stage.style.setProperty('--projects-reveal', `${projectsReveal.toFixed(3)}%`);
			stage.style.setProperty('--projects-reveal-edge', `${projectsRevealEdge.toFixed(3)}%`);
			stage.style.setProperty('--projects-reveal-x', `${tuning.revealX.toFixed(3)}%`);
			stage.style.setProperty('--projects-reveal-y', `${tuning.revealY.toFixed(3)}%`);
			stage.dataset.activePanel = progress > 0.74 ? 'projects' : 'hero';
			stage.dispatchEvent(new CustomEvent('z-space-progress'));
		};

		const updateScrollProgress = () => {
			const rect = stage.getBoundingClientRect();
			const scrollableDistance = Math.max(1, stage.offsetHeight - window.innerHeight);
			const rawProgress = clamp(-rect.top / scrollableDistance, 0, 1);
			const animationStart = clamp(Math.min(tuning.scrollStart, tuning.scrollEnd - 0.05), 0, 0.95);
			const animationEnd = clamp(Math.max(tuning.scrollEnd, animationStart + 0.05), animationStart + 0.05, 1);

			state.rawProgress = rawProgress;
			state.targetProgress = clamp((rawProgress - animationStart) / (animationEnd - animationStart), 0, 1);
			updatePanelVars(state.targetProgress);
		};

		const destroyLenis = () => {
			lenisSetupToken += 1;

			if (lenisRafId) {
				window.cancelAnimationFrame(lenisRafId);
				lenisRafId = 0;
			}

			lenis?.destroy();
			lenis = null;
		};

		const setupLenis = async () => {
			destroyLenis();
			const setupToken = lenisSetupToken;

			if (!tuning.lenisEnabled || prefersReducedMotion) {
				return;
			}

			try {
				lenisImportPromise ??= import('https://esm.sh/lenis@1.3.11');
				const { default: Lenis } = await lenisImportPromise;
				if (setupToken !== lenisSetupToken) return;

				lenis = new Lenis({
					lerp: tuning.lenisLerp,
					wheelMultiplier: tuning.lenisWheelMultiplier,
					touchMultiplier: 1.2,
					smoothWheel: true,
					syncTouch: false,
					anchors: true,
					autoResize: true,
				});
				lenis.on('scroll', updateScrollProgress);
			} catch (error) {
				if (setupToken !== lenisSetupToken) return;
				console.warn('Lenis could not be loaded. Falling back to native scroll.', error);
				return;
			}

			const raf = (time) => {
				if (setupToken !== lenisSetupToken) return;
				lenis?.raf(time);
				lenisRafId = window.requestAnimationFrame(raf);
			};

			lenisRafId = window.requestAnimationFrame(raf);
		};

		const setupHeroGui = async () => {
			if (!heroGuiEnabled || gui) return;

			try {
				const guiModule = await import('https://esm.sh/lil-gui@0.20.0');
				const GUI = guiModule.GUI ?? guiModule.default;
				const controllers = [];
				const refreshFromGui = (persist = true) => {
					updateScrollProgress();
					updatePanelVars(state.targetProgress);
					startAnimation();
					if (persist) saveHeroTuning(tuning);
				};
				const track = (controller) => {
					controllers.push(controller);
					return controller;
				};
				const addNumber = (folder, property, min, max, step, label = property) => {
					track(folder.add(tuning, property, min, max, step).name(label).onChange(() => refreshFromGui()));
				};
				const addToggle = (folder, property, label = property, onChange = refreshFromGui) => {
					track(folder.add(tuning, property).name(label).onChange(onChange));
				};
				const updateDisplays = () => controllers.forEach((controller) => controller.updateDisplay());
				const resetTuning = () => {
					Object.assign(tuning, makeTuningDefaults(isMobile));
					safeStorage.remove(HERO_GUI_TUNING_KEY);
					updateDisplays();
					setupLenis();
					if (tuning.postprocessingEnabled) {
						ensurePostprocessing().then(() => startAnimation());
					}
					refreshFromGui(false);
				};
				const copyTuning = () => {
					const payload = JSON.stringify(snapshotTuning(tuning), null, 2);
					navigator.clipboard?.writeText(payload).catch(() => undefined);
					console.info('Hero tuning snapshot:', payload);
				};

				safeStorage.set(HERO_GUI_ENABLED_KEY, 'true');
				gui = new GUI({ title: 'Hero controls', width: 340 });
				gui.domElement.classList.add('hero-debug-gui');

				const layoutFolder = gui.addFolder('Layout');
				addNumber(layoutFolder, 'vortexX', -12, 12, 0.01, 'vortex x');
				addNumber(layoutFolder, 'vortexY', -8, 10, 0.01, 'vortex y');
				addNumber(layoutFolder, 'revealX', 0, 100, 0.1, 'reveal x');
				addNumber(layoutFolder, 'revealY', 0, 100, 0.1, 'reveal y');
				addNumber(layoutFolder, 'headlineBaseRem', 0, 8, 0.01, 'headline offset');
				addNumber(layoutFolder, 'headlineScrollVh', 0, 32, 0.1, 'headline scroll');

				const scrollFolder = gui.addFolder('Scroll timing');
				addNumber(scrollFolder, 'scrollStart', 0, 0.95, 0.001, 'start');
				addNumber(scrollFolder, 'scrollEnd', 0.05, 1, 0.001, 'end');
				addNumber(scrollFolder, 'heroExitStart', 0, 1, 0.001, 'hero exit start');
				addNumber(scrollFolder, 'heroExitEnd', 0, 1, 0.001, 'hero exit end');
				addNumber(scrollFolder, 'projectsEnterStart', 0, 1, 0.001, 'projects start');
				addNumber(scrollFolder, 'projectsEnterEnd', 0, 1, 0.001, 'projects end');

				const particleFolder = gui.addFolder('Particles');
				addNumber(particleFolder, 'particleSize', 0.02, 0.8, 0.001, 'size');
				addNumber(particleFolder, 'particleToneMix', 0, 1, 0.001, 'tone mix');
				addNumber(particleFolder, 'vortexOpenStart', 0, 1, 0.001, 'open start');
				addNumber(particleFolder, 'vortexOpenEnd', 0, 1, 0.001, 'open end');
				addNumber(particleFolder, 'coreFinal', 0, 28, 0.01, 'core radius');
				addNumber(particleFolder, 'innerPush', 0, 36, 0.01, 'inner push');
				addNumber(particleFolder, 'latePush', 0, 24, 0.01, 'late push');
				addNumber(particleFolder, 'depthPush', -20, 30, 0.01, 'depth push');
				addNumber(particleFolder, 'streakBaseLength', 0, 1, 0.001, 'streak base');
				addNumber(particleFolder, 'streakMaxLength', 0, 8, 0.01, 'streak max');

				const revealFolder = gui.addFolder('Reveal and fade');
				addNumber(revealFolder, 'stretchStart', 0, 1, 0.001, 'stretch start');
				addNumber(revealFolder, 'stretchPeak', 0, 1, 0.001, 'stretch peak');
				addNumber(revealFolder, 'stretchFadeStart', 0, 1, 0.001, 'stretch fade start');
				addNumber(revealFolder, 'stretchFadeEnd', 0, 1, 0.001, 'stretch fade end');
				addNumber(revealFolder, 'particleFadeStart', 0, 1, 0.001, 'particle fade start');
				addNumber(revealFolder, 'particleFadeEnd', 0, 1, 0.001, 'particle fade end');
				addNumber(revealFolder, 'projectRevealStart', 0, 1, 0.001, 'project reveal start');
				addNumber(revealFolder, 'projectRevealEnd', 0, 1, 0.001, 'project reveal end');
				addNumber(revealFolder, 'projectRevealMax', 0, 180, 0.1, 'project reveal max');
				addNumber(revealFolder, 'projectRevealFeather', 0, 60, 0.1, 'project feather');

				const fxFolder = gui.addFolder('FX');
				addToggle(fxFolder, 'postprocessingEnabled', 'postprocessing', async () => {
					if (tuning.postprocessingEnabled) {
						await ensurePostprocessing();
					}
					refreshFromGui();
				});
				addNumber(fxFolder, 'bloomStrength', 0, 3, 0.001, 'bloom strength');
				addNumber(fxFolder, 'bloomRadius', 0, 1, 0.001, 'bloom radius');
				addNumber(fxFolder, 'bloomThreshold', 0, 1, 0.001, 'bloom threshold');
				addNumber(fxFolder, 'chromaAmount', 0, 0.006, 0.00001, 'chroma amount');
				addNumber(fxFolder, 'chromaStart', 0, 1, 0.001, 'chroma start');
				addNumber(fxFolder, 'chromaPeak', 0, 1, 0.001, 'chroma peak');
				addNumber(fxFolder, 'chromaFadeStart', 0, 1, 0.001, 'chroma fade start');
				addNumber(fxFolder, 'chromaFadeEnd', 0, 1, 0.001, 'chroma fade end');

				const smoothFolder = gui.addFolder('Smooth scroll');
				addToggle(smoothFolder, 'lenisEnabled', 'lenis enabled', () => {
					saveHeroTuning(tuning);
					setupLenis();
					refreshFromGui(false);
				});
				track(
					smoothFolder
						.add(tuning, 'lenisLerp', 0.02, 0.35, 0.001)
						.name('lenis lerp')
						.onFinishChange(() => {
							saveHeroTuning(tuning);
							setupLenis();
						}),
				);
				track(
					smoothFolder
						.add(tuning, 'lenisWheelMultiplier', 0.1, 1.8, 0.001)
						.name('wheel multiplier')
						.onFinishChange(() => {
							saveHeroTuning(tuning);
							setupLenis();
						}),
				);

				const actions = {
					copyTuning,
					resetTuning,
					hideGui: () => {
						gui?.destroy();
						gui = null;
					},
				};
				const actionsFolder = gui.addFolder('Actions');
				actionsFolder.add(actions, 'copyTuning').name('copy tuning');
				actionsFolder.add(actions, 'resetTuning').name('reset tuning');
				actionsFolder.add(actions, 'hideGui').name('hide gui');
				scrollFolder.close();
				particleFolder.close();
				revealFolder.close();
				fxFolder.close();
				smoothFolder.close();
				actionsFolder.close();
			} catch (error) {
				console.warn('lil-gui could not be loaded for the hero controls.', error);
			}
		};

		const resize = () => {
			const { clientWidth, clientHeight } = container;
			if (!clientWidth || !clientHeight) return;
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, pixelRatioCap));
			composer?.setPixelRatio?.(Math.min(window.devicePixelRatio, isMobile ? 1 : 1.35));
			renderer.setSize(clientWidth, clientHeight, false);
			composer?.setSize(clientWidth, clientHeight);
			camera.aspect = clientWidth / clientHeight;
			camera.updateProjectionMatrix();
			updateScrollProgress();
		};

		const onPointerMove = (event) => {
			const rect = container.getBoundingClientRect();
			pointerTarget.x = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
			pointerTarget.y = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
		};

		window.addEventListener('scroll', updateScrollProgress, { passive: true });
		window.addEventListener('resize', resize);
		stage.addEventListener('pointermove', onPointerMove, { passive: true });

		const resizeObserver = new ResizeObserver(resize);
		resizeObserver.observe(container);
		resize();
		updatePanelVars(state.targetProgress);

		setupLenis();

		const startAnimation = () => {
			if (!frameId) {
				frameId = window.requestAnimationFrame(animate);
			}
		};

		const stopAnimation = () => {
			if (frameId) {
				window.cancelAnimationFrame(frameId);
				frameId = 0;
			}
		};

		const animate = (time) => {
			frameId = 0;
			if (!isSceneVisible) return;

			const elapsed = time * 0.001;
			const progressEase = prefersReducedMotion ? 1 : 0.085;

			state.progress += (state.targetProgress - state.progress) * progressEase;
			pointer.x += (pointerTarget.x - pointer.x) * 0.045;
			pointer.y += (pointerTarget.y - pointer.y) * 0.045;

			const easedProgress = smoothstep(0, 1, state.progress);
			camera.position.x = pointer.x * (isMobile ? 0.55 : 1.3);
			camera.position.y = -pointer.y * (isMobile ? 0.35 : 0.76);
			camera.position.z = lerp(18, -50, easedProgress);
			camera.lookAt(
				pointer.x * (isMobile ? 1.4 : 2.4),
				-pointer.y * (isMobile ? 0.9 : 1.6),
				lerp(-14, -74, easedProgress),
			);

			if (!prefersReducedMotion) {
				const data = particleGeometry.attributes.position.array;
				const colorData = particleGeometry.attributes.color.array;
				const streakData = streakGeometry.attributes.position.array;
				const streakColorData = streakGeometry.attributes.color.array;
				const streakAlphaData = streakGeometry.attributes.alpha.array;
				const scrollPulse = state.progress * Math.PI * 2;
				const vortexOpen = smoothstep(tuning.vortexOpenStart, tuning.vortexOpenEnd, state.progress);
				const particlePresence = 1 - smoothstep(tuning.particleFadeStart, tuning.particleFadeEnd, state.progress);
				const speedStretch =
					smoothstep(tuning.stretchStart, tuning.stretchPeak, state.progress) *
					(1 - smoothstep(tuning.stretchFadeStart, tuning.stretchFadeEnd, state.progress));
				const streakPresence = clamp(speedStretch + tuning.streakBaseLength * 0.9, 0, 1);
				const lateOpen = smoothstep(0.5, tuning.particleFadeEnd, state.progress);
				const coreRadius = lerp(baseCoreRadius, tuning.coreFinal, vortexOpen);

				for (let index = 0; index < particleCount; index += 1) {
					const dataIndex = index * 3;
					const streakIndex = index * 6;
					const alphaIndex = index * 2;
					const depth = particleDepth[index];
					const depthProgress = clamp((zStart - depth) / (zStart - zEnd), 0, 1);
					const swirl =
						particleAngles[index] +
						elapsed * lerp(0.12, 0.48, speedStretch) +
						scrollPulse * 0.34 +
						depth * 0.028 +
						particleOffsets[index] * 0.1;
					const pulse =
						coreRadius +
						particleRadius[index] +
						(1 - smoothstep(isMobile ? 3.2 : 4.4, isMobile ? 7.4 : 10.2, particleRadius[index])) *
							vortexOpen *
							tuning.innerPush +
						lateOpen * (1 - smoothstep(isMobile ? 5.4 : 7.2, isMobile ? 9.2 : 12.4, particleRadius[index])) *
							tuning.latePush +
						depthProgress * vortexOpen * tuning.depthPush +
						Math.sin(elapsed * 0.82 + particleOffsets[index] + depth * 0.08) * 0.16 +
						vortexOpen * Math.sin(particleSeeds[index] * 9.2 + scrollPulse) * 0.38;
					const x = Math.cos(swirl) * pulse;
					const y = Math.sin(swirl) * pulse * 0.64;
					const tangentX = -Math.sin(swirl);
					const tangentY = Math.cos(swirl) * 0.64;
					const radialX = Math.cos(swirl);
					const radialY = Math.sin(swirl) * 0.64;
					const streakLength = lerp(tuning.streakBaseLength, tuning.streakMaxLength, speedStretch) * lerp(0.8, 1.35, depthProgress);
					const streakPull = lerp(0.28, 1.15, speedStretch);
					const tailX = x - (tangentX * 0.62 + radialX * streakPull) * streakLength;
					const tailY = y - (tangentY * 0.62 + radialY * streakPull) * streakLength;
					const tailZ = depth + lerp(0.05, 1.65, speedStretch);
					const glow = 0.22 + smoothstep(0.18, 0.78, depthProgress) * 0.54 + speedStretch * 0.22;
					const toneSeed = particleSeeds[index];
					const cyanTone = 0.5 + Math.sin(toneSeed * Math.PI * 2 + particleOffsets[index]) * 0.5;
					const emeraldTone = 0.5 + Math.sin(toneSeed * 12.7 + depth * 0.04) * 0.5;
					const whiteSpark = smoothstep(0.86, 1, toneSeed);
					const red = clamp(
						0.18 + glow * 0.42 + tuning.particleToneMix * (whiteSpark * 0.22 - cyanTone * 0.08),
						0,
						1,
					);
					const green = clamp(
						0.64 + glow * 0.34 + tuning.particleToneMix * (emeraldTone * 0.16 + whiteSpark * 0.12),
						0,
						1,
					);
					const blue = clamp(
						0.48 + glow * 0.46 + tuning.particleToneMix * (cyanTone * 0.24 + whiteSpark * 0.18 - emeraldTone * 0.06),
						0,
						1,
					);
					const streakTailShade = 0.48 + speedStretch * 0.08;
					const streakHeadShade = 0.86 + speedStretch * 0.14;
					const alpha =
						(0.04 + streakPresence * 0.78) *
						particlePresence *
						smoothstep(0, 0.24, particleRadius[index]);

					data[dataIndex] = x;
					data[dataIndex + 1] = y;
					data[dataIndex + 2] = depth;
					colorData[dataIndex] = red;
					colorData[dataIndex + 1] = green;
					colorData[dataIndex + 2] = blue;
					streakData[streakIndex] = tailX;
					streakData[streakIndex + 1] = tailY;
					streakData[streakIndex + 2] = tailZ;
					streakData[streakIndex + 3] = x;
					streakData[streakIndex + 4] = y;
					streakData[streakIndex + 5] = depth;
					streakColorData[streakIndex] = red * streakTailShade;
					streakColorData[streakIndex + 1] = green * streakTailShade;
					streakColorData[streakIndex + 2] = blue * streakTailShade;
					streakColorData[streakIndex + 3] = red * streakHeadShade;
					streakColorData[streakIndex + 4] = green * streakHeadShade;
					streakColorData[streakIndex + 5] = blue * streakHeadShade;
					streakAlphaData[alphaIndex] = 0.02 + alpha * 0.16;
					streakAlphaData[alphaIndex + 1] = alpha;
				}

				particleGeometry.attributes.position.needsUpdate = true;
				particleGeometry.attributes.color.needsUpdate = true;
				streakGeometry.attributes.position.needsUpdate = true;
				streakGeometry.attributes.color.needsUpdate = true;
				streakGeometry.attributes.alpha.needsUpdate = true;
				particleCloud.position.x = tuning.vortexX;
				particleCloud.position.y = tuning.vortexY;
				particleCloud.rotation.y = 0.04 + Math.sin(elapsed * 0.12) * 0.012;
				particleCloud.rotation.z = -0.025 + Math.cos(elapsed * 0.09) * 0.006;
				streakCloud.rotation.copy(particleCloud.rotation);
				streakCloud.position.x = tuning.vortexX;
				streakCloud.position.y = tuning.vortexY;
				particleMaterial.size = tuning.particleSize;
				particleMaterial.opacity = particlePresence;
				particleCloud.visible = particlePresence > 0.01;
				streakCloud.visible = particlePresence > 0.01 && streakPresence > 0.01;
				streakMaterial.uniforms.uOpacity.value = lerp(0.16, 0.98, streakPresence) * particlePresence;
			}

			const fxStretch =
				smoothstep(tuning.stretchStart, tuning.stretchPeak, state.progress) *
				(1 - smoothstep(tuning.stretchFadeStart, tuning.stretchFadeEnd, state.progress));
			const chromaEnter =
				tuning.chromaStart <= 0
					? 1
					: smoothstep(tuning.chromaStart, Math.max(tuning.chromaPeak, tuning.chromaStart + 0.01), state.progress);
			const chromaPulse =
				chromaEnter * (1 - smoothstep(tuning.chromaFadeStart, tuning.chromaFadeEnd, state.progress));
			const postprocessingActive = Boolean(
				composer &&
				bloomPass &&
				chromaPass &&
				tuning.postprocessingEnabled &&
				!prefersReducedMotion
			);

			if (postprocessingActive) {
				bloomPass.enabled = true;
				bloomPass.strength = tuning.bloomStrength * lerp(0.82, 1.18, fxStretch);
				bloomPass.radius = tuning.bloomRadius;
				bloomPass.threshold = tuning.bloomThreshold;
				chromaPass.enabled = chromaPulse > 0.001 && tuning.chromaAmount > 0;
				chromaPass.uniforms.uAmount.value = tuning.chromaAmount * chromaPulse;
				composer.render();
			} else {
				renderer.render(scene, camera);
			}

			if (isSceneVisible) {
				startAnimation();
			}
		};

		visibilityObserver = new IntersectionObserver(
			([entry]) => {
				isSceneVisible = Boolean(entry?.isIntersecting);
				if (isSceneVisible) {
					startAnimation();
				} else {
					stopAnimation();
				}
			},
			{ rootMargin: '25% 0px' },
		);
		visibilityObserver.observe(stage);
		startAnimation();
		setupHeroGui();

		const cleanup = () => {
			stopAnimation();
			window.removeEventListener('scroll', updateScrollProgress);
			window.removeEventListener('resize', resize);
			stage.removeEventListener('pointermove', onPointerMove);
			resizeObserver.disconnect();
			visibilityObserver?.disconnect();
			destroyLenis();
			particleGeometry.dispose();
			streakGeometry.dispose();
			particleMaterial.dispose();
			streakMaterial.dispose();
			particleSprite?.dispose();
			composer?.dispose();
			gui?.destroy();
			renderer.dispose();
		};

		window.addEventListener('pagehide', cleanup, { once: true });
	}

	containers.forEach(mountScrollSpace);
</script>

<style>
	.scroll-space-scene {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.scroll-space-scene :global(canvas) {
		display: block;
		width: 100%;
		height: 100%;
	}

	:global(.hero-debug-gui) {
		position: fixed !important;
		top: 5rem !important;
		right: 1rem !important;
		z-index: 9999 !important;
		--background-color: rgba(6, 12, 9, 0.92);
		--text-color: #edfff7;
		--title-background-color: rgba(17, 31, 25, 0.96);
		--widget-color: rgba(13, 24, 19, 0.92);
		--hover-color: rgba(52, 211, 153, 0.18);
		--focus-color: rgba(52, 211, 153, 0.28);
		--number-color: #7ef6c4;
		--string-color: #7ef6c4;
		border: 1px solid rgba(126, 246, 196, 0.22);
		border-radius: 12px;
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.4);
	}

	@media (max-width: 720px) {
		:global(.hero-debug-gui) {
			left: 1rem !important;
			right: 1rem !important;
			width: auto !important;
		}
	}

	:global(html.lenis),
	:global(html.lenis body) {
		height: auto;
	}

	:global(.lenis.lenis-smooth) {
		scroll-behavior: auto !important;
	}

	:global(.lenis.lenis-smooth [data-lenis-prevent]) {
		overscroll-behavior: contain;
	}

	:global(.lenis.lenis-stopped) {
		overflow: hidden;
	}

	:global(.lenis.lenis-smooth iframe) {
		pointer-events: none;
	}
</style>
