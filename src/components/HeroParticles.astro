<div class="hero-particles-frame">
	<div class="hero-particles-canvas" data-hero-particles></div>
</div>

<script type="module" is:inline>
	import * as THREE from 'https://esm.sh/three@0.161.0';

	const containers = document.querySelectorAll('[data-hero-particles]');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	function makeSprite() {
		const canvas = document.createElement('canvas');
		canvas.width = 128;
		canvas.height = 128;

		const context = canvas.getContext('2d');
		if (!context) return null;

		const gradient = context.createRadialGradient(64, 64, 4, 64, 64, 64);
		gradient.addColorStop(0, 'rgba(190, 255, 230, 1)');
		gradient.addColorStop(0.12, 'rgba(120, 255, 196, 1)');
		gradient.addColorStop(0.34, 'rgba(71, 223, 155, 0.98)');
		gradient.addColorStop(0.52, 'rgba(71, 223, 155, 0.2)');
		gradient.addColorStop(1, 'rgba(71, 223, 155, 0)');
		context.fillStyle = gradient;
		context.fillRect(0, 0, 128, 128);

		return new THREE.CanvasTexture(canvas);
	}

	function addDepthStyling(material, settings) {
		material.onBeforeCompile = (shader) => {
			shader.uniforms.uDepthStart = { value: settings.depthStart };
			shader.uniforms.uDepthEnd = { value: settings.depthEnd };
			shader.uniforms.uFarBlur = { value: settings.farBlur };
			shader.uniforms.uNearScale = { value: settings.nearScale };
			shader.uniforms.uFarFade = { value: settings.farFade };
			shader.uniforms.uFarDim = { value: settings.farDim };
			shader.uniforms.uNearAlpha = { value: settings.nearAlpha };
			shader.uniforms.uNearGlow = { value: settings.nearGlow };

			shader.vertexShader = shader.vertexShader
				.replace(
					'#include <common>',
					`#include <common>
					varying float vDepthProgress;
					varying float vNearFocus;
					varying float vFarHaze;
					uniform float uDepthStart;
					uniform float uDepthEnd;
					uniform float uFarBlur;
					uniform float uNearScale;`,
				)
				.replace(
					'gl_PointSize = size;',
					`vDepthProgress = clamp((position.z - uDepthStart) / (uDepthEnd - uDepthStart), 0.0, 1.0);
					vNearFocus = smoothstep(0.62, 1.0, vDepthProgress);
					vFarHaze = 1.0 - smoothstep(0.18, 0.58, vDepthProgress);
					gl_PointSize = size * (1.0 + vFarHaze * uFarBlur + vNearFocus * uNearScale);`,
				);

			shader.fragmentShader = shader.fragmentShader
				.replace(
					'#include <common>',
					`#include <common>
					varying float vDepthProgress;
					varying float vNearFocus;
					varying float vFarHaze;
					uniform float uFarFade;
					uniform float uFarDim;
					uniform float uNearAlpha;
					uniform float uNearGlow;`,
				)
				.replace(
					'#include <color_fragment>',
					`#include <color_fragment>
					diffuseColor.rgb *= 1.0 - uFarDim * vFarHaze;
					diffuseColor.rgb *= 1.0 + uNearGlow * vNearFocus;
					diffuseColor.a *= clamp(1.0 - uFarFade * vFarHaze + uNearAlpha * vNearFocus, 0.12, 2.4);`,
				);
		};

		material.customProgramCacheKey = () => JSON.stringify(settings);
		material.needsUpdate = true;
	}

	function mountHeroField(container) {
		if (container.dataset.ready === 'true') return;
		container.dataset.ready = 'true';
		const frame = container.closest('.hero-particles-frame') || container;
		const hero = frame.closest('.hero') || document;
		const headline = hero.querySelector('.hero__headline');
		const title = hero.querySelector('.hero__name');
		const titleArrow = hero.querySelector('.hero__name-arrow');

		const scene = new THREE.Scene();
		const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 140);
		camera.position.set(0, 0, 18);
		const cameraAim = new THREE.Vector3(0, 0, -30);
		const cameraAimTarget = new THREE.Vector3(0, 0, -30);

		const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.75));
		renderer.setClearColor(0x000000, 0);
		container.appendChild(renderer.domElement);

		const sprite = makeSprite();
		const material = new THREE.PointsMaterial({
			color: 0xedfff7,
			size: 0.2,
			transparent: true,
			opacity: 1,
			map: sprite,
			vertexColors: true,
			blending: THREE.AdditiveBlending,
			depthWrite: false,
		});
		material.toneMapped = false;

		const bloomMaterial = new THREE.PointsMaterial({
			color: 0xf2fff9,
			size: 0.34,
			transparent: true,
			opacity: 0.12,
			map: sprite,
			vertexColors: true,
			blending: THREE.AdditiveBlending,
			depthWrite: false,
		});
		bloomMaterial.toneMapped = false;

		const emissiveMaterial = new THREE.PointsMaterial({
			color: 0xffffff,
			size: 0.56,
			transparent: true,
			opacity: 0.08,
			map: sprite,
			vertexColors: true,
			blending: THREE.AdditiveBlending,
			depthWrite: false,
		});
		emissiveMaterial.toneMapped = false;

		const isMobile = window.innerWidth < 768;
		const count = isMobile ? 1200 : 2000;
		const positions = new Float32Array(count * 3);
		const colors = new Float32Array(count * 3);
		const radial = new Float32Array(count);
		const angles = new Float32Array(count);
		const depths = new Float32Array(count);
		const offsets = new Float32Array(count);
		const colorVariants = new Float32Array(count);

		const tunnelDepth = isMobile ? 62 : 78;
		const zStart = -tunnelDepth;
		const zEnd = 18;

		addDepthStyling(material, {
			depthStart: zStart,
			depthEnd: zEnd,
			farBlur: 0.08,
			nearScale: 0.04,
			farFade: 0.28,
			farDim: 0.32,
			nearAlpha: 0.12,
			nearGlow: 0.18,
		});
		addDepthStyling(bloomMaterial, {
			depthStart: zStart,
			depthEnd: zEnd,
			farBlur: 0.68,
			nearScale: 0.12,
			farFade: 0.18,
			farDim: 0.14,
			nearAlpha: 0.24,
			nearGlow: 0.3,
		});
		addDepthStyling(emissiveMaterial, {
			depthStart: zStart,
			depthEnd: zEnd,
			farBlur: 1.02,
			nearScale: 0.22,
			farFade: 0.28,
			farDim: 0.18,
			nearAlpha: 0.48,
			nearGlow: 0.56,
		});

		for (let i = 0; i < count; i += 1) {
			const ringBias = Math.pow(Math.random(), 1.18);
			const radiusBase = isMobile ? 3.7 : 4.7;
			const radiusSpread = isMobile ? 8.1 : 10.2;
			const angle = Math.random() * Math.PI * 2;
			const depth = zStart + Math.random() * (zEnd - zStart);
			const innerPulse = Math.sin(depth * 0.16) * 0.45;
			const radius = radiusBase + ringBias * radiusSpread + innerPulse;

			radial[i] = radius;
			angles[i] = angle;
			depths[i] = depth;
			offsets[i] = Math.random() * Math.PI * 2;
			colorVariants[i] = Math.random();

			const dataIndex = i * 3;
			positions[dataIndex] = Math.cos(angle) * radius;
			positions[dataIndex + 1] = Math.sin(angle) * radius * 0.68;
			positions[dataIndex + 2] = depth;
			colors[dataIndex] = 0.04;
			colors[dataIndex + 1] = 0.14;
			colors[dataIndex + 2] = 0.1;
		}

		const geometry = new THREE.BufferGeometry();
		geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
		geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));

		const points = new THREE.Points(geometry, material);
		const bloomPoints = new THREE.Points(geometry, bloomMaterial);
		const emissivePoints = new THREE.Points(geometry, emissiveMaterial);
		points.rotation.x = -0.08;
		points.rotation.y = 0.08;
		points.rotation.z = -0.04;
		bloomPoints.rotation.x = points.rotation.x;
		bloomPoints.rotation.y = points.rotation.y;
		bloomPoints.rotation.z = points.rotation.z;
		emissivePoints.rotation.x = points.rotation.x;
		emissivePoints.rotation.y = points.rotation.y;
		emissivePoints.rotation.z = points.rotation.z;
		scene.add(points);
		scene.add(bloomPoints);
		scene.add(emissivePoints);

		const pointer = { x: 0, y: 0 };
		const pointerTarget = { x: 0, y: 0 };
		const vortexAnchor = { x: 0, y: 0 };
		const vortexAnchorTarget = { x: 0, y: 0 };
		const vortexAnchorOffsetX = 0;
		const vortexFieldShiftX = isMobile ? 0.9 : 1.7;
		const vortexMaskShiftPercentX = isMobile ? 5 : 7;
		let isPointerInside = false;
		let hoverBlend = 0;

		const updateVortexAnchorTarget = () => {
			if (!headline || !title || !titleArrow) {
				vortexAnchorTarget.x = 0;
				vortexAnchorTarget.y = 0;
				return;
			}

			const frameRect = frame.getBoundingClientRect();
			const headlineRect = headline.getBoundingClientRect();
			if (!frameRect.width || !frameRect.height || !headlineRect.width || !headlineRect.height) {
				vortexAnchorTarget.x = 0;
				vortexAnchorTarget.y = 0;
				return;
			}

			const arrowCenterX =
				headlineRect.left + title.offsetLeft + titleArrow.offsetLeft + titleArrow.offsetWidth / 2;
			const arrowCenterY =
				headlineRect.top + title.offsetTop + titleArrow.offsetTop + titleArrow.offsetHeight / 2;
			const arrowPercentX = ((arrowCenterX - frameRect.left) / frameRect.width) * 100;
			const arrowPercentY = ((arrowCenterY - frameRect.top) / frameRect.height) * 100;
			const ndcX = ((arrowCenterX - frameRect.left) / frameRect.width) * 2 - 1;
			const ndcY = -(((arrowCenterY - frameRect.top) / frameRect.height) * 2 - 1);
			const rayPoint = new THREE.Vector3(ndcX, ndcY, 0.5).unproject(camera);
			const rayDirection = rayPoint.sub(camera.position).normalize();
			const planeZ = 0;
			const distance = (planeZ - camera.position.z) / rayDirection.z;

			if (!Number.isFinite(distance)) {
				vortexAnchorTarget.x = 0;
				vortexAnchorTarget.y = 0;
				return;
			}

			const shiftedPercentX = THREE.MathUtils.clamp(
				arrowPercentX + vortexMaskShiftPercentX,
				0,
				100,
			);
			const xValue = `${shiftedPercentX.toFixed(3)}%`;
			const yValue = `${arrowPercentY.toFixed(3)}%`;
			hero.style.setProperty('--vortex-center-x', xValue);
			hero.style.setProperty('--vortex-center-y', yValue);
			frame.style.setProperty('--vortex-center-x', xValue);
			frame.style.setProperty('--vortex-center-y', yValue);

			const intersection = camera.position.clone().add(rayDirection.multiplyScalar(distance));
			vortexAnchorTarget.x = intersection.x + vortexAnchorOffsetX + vortexFieldShiftX;
			vortexAnchorTarget.y = intersection.y;
		};

		const updatePointerFromEvent = (event) => {
			const rect = frame.getBoundingClientRect();
			pointerTarget.x = ((event.clientX - rect.left) / rect.width - 0.5) * 0.9;
			pointerTarget.y = ((event.clientY - rect.top) / rect.height - 0.5) * 0.6;
		};
		const onPointerEnter = (event) => {
			isPointerInside = true;
		};
		const onPointerMove = (event) => {
			isPointerInside = true;
			updatePointerFromEvent(event);
		};
		const onPointerLeave = () => {
			isPointerInside = false;
		};
		const onPointerCancel = (event) => {
			isPointerInside = false;
		};
		frame.addEventListener('pointerenter', onPointerEnter);
		frame.addEventListener('pointermove', onPointerMove);
		frame.addEventListener('pointerleave', onPointerLeave);
		frame.addEventListener('pointercancel', onPointerCancel);

		const resize = () => {
			const { clientWidth, clientHeight } = container;
			if (!clientWidth || !clientHeight) return;
			renderer.setSize(clientWidth, clientHeight, false);
			camera.aspect = clientWidth / clientHeight;
			camera.updateProjectionMatrix();
			updateVortexAnchorTarget();
		};

		const resizeObserver = new ResizeObserver(resize);
		resizeObserver.observe(container);
		if (headline) resizeObserver.observe(headline);
		resize();
		document.fonts?.ready?.then(updateVortexAnchorTarget).catch(() => {});

		let frameId = 0;
		const animate = (time) => {
			frameId = window.requestAnimationFrame(animate);

			if (!prefersReducedMotion) {
				const data = geometry.attributes.position.array;
				const particleColors = geometry.attributes.color.array;
				const waveTime = time * 0.001;
				const speed = isMobile ? 0.038 : 0.062;
				const pointerEase = isPointerInside ? 0.11 : 0.05;
				const hoverEase = isPointerInside ? 0.08 : 0.06;
				const anchorEase = isMobile ? 0.12 : 0.1;

				hoverBlend += ((isPointerInside ? 1 : 0) - hoverBlend) * hoverEase;

				pointer.x += (pointerTarget.x - pointer.x) * pointerEase;
				pointer.y += (pointerTarget.y - pointer.y) * pointerEase;
				vortexAnchor.x += (vortexAnchorTarget.x - vortexAnchor.x) * anchorEase;
				vortexAnchor.y += (vortexAnchorTarget.y - vortexAnchor.y) * anchorEase;

				for (let i = 0; i < count; i += 1) {
					const dataIndex = i * 3;
					let depth = depths[i] + speed;
					if (depth > zEnd) {
						depth = zStart;
					}
					depths[i] = depth;

					const swirl = angles[i] + waveTime * 0.14 + depth * 0.036 + offsets[i] * 0.15;
					const radiusPulse =
						radial[i] +
						Math.sin(waveTime * 0.7 + offsets[i] + depth * 0.08) * 0.12 +
						Math.cos(waveTime * 0.55 + offsets[i]) * 0.035;
					const depthProgress = (depth - zStart) / (zEnd - zStart);
					const inwardPull = 1 - depthProgress * 0.18;
					const influenceX = pointer.x * hoverBlend;
					const influenceY = pointer.y * hoverBlend;
					const nearFocus = Math.pow(depthProgress, 3.4);
					const farMist = Math.pow(1 - depthProgress, 1.85);
					const nearCameraBoost = nearFocus * 0.58;
					const glow = 0.08 + Math.pow(depthProgress, 2.35) * 1.42 + nearCameraBoost;

					data[dataIndex] =
						Math.cos(swirl) * radiusPulse * inwardPull +
						influenceX * (2.4 * depthProgress) +
						vortexAnchor.x;
					data[dataIndex + 1] =
						Math.sin(swirl) * radiusPulse * 0.62 * inwardPull +
						influenceY * (1.3 * depthProgress) +
						vortexAnchor.y;
					data[dataIndex + 2] = depth;

					let red = 0.082 + glow * 0.4 + nearFocus * 0.3 - farMist * 0.008;
					let green = 0.136 + glow * 0.56 + nearFocus * 0.16 - farMist * 0.02;
					let blue = 0.132 + glow * 0.46 + nearFocus * 0.34 - farMist * 0.012;
					const colorVariant = colorVariants[i];

					if (colorVariant < 0.18) {
						red *= 0.94;
						green *= 0.98;
						blue *= 1.38;
					} else if (colorVariant > 0.76) {
						red *= 0.84;
						green *= 1.24;
						blue *= 0.74;
					} else if (colorVariant > 0.34 && colorVariant < 0.58) {
						red *= 1.95;
						green *= 1.52;
						blue *= 1.82;
					}

					particleColors[dataIndex] = Math.min(1, red);
					particleColors[dataIndex + 1] = Math.min(1, green);
					particleColors[dataIndex + 2] = Math.min(1, blue);
				}

				geometry.attributes.position.needsUpdate = true;
				geometry.attributes.color.needsUpdate = true;
				const livePointerX = pointer.x * hoverBlend;
				const livePointerY = pointer.y * hoverBlend;
				const pointerDepth = Math.min(1, Math.hypot(livePointerX, livePointerY));
				const cameraRangeX = isMobile ? 1.45 : 2.75;
				const cameraRangeY = isMobile ? 0.85 : 1.55;
				const lookRangeX = isMobile ? 6.4 : 9.5;
				const lookRangeY = isMobile ? 3.1 : 4.9;
				const targetCameraZ = 18 - pointerDepth * 0.4;

				if (title) {
					const titleShiftX = livePointerX * (isMobile ? 1.8 : 2.6) + Math.sin(waveTime * 0.92) * 0.55;
					const titleShiftY = -livePointerY * (isMobile ? 1.1 : 1.6) + Math.cos(waveTime * 0.76) * 0.35;
					const titleTilt = livePointerX * (isMobile ? 0.45 : 0.7) + Math.sin(waveTime * 0.54) * 0.18;
					const titleGlow = THREE.MathUtils.clamp(
						0.18 + pointerDepth * 0.32 + (Math.sin(waveTime * 1.08) + 1) * 0.08,
						0,
						0.75,
					);

					title.style.setProperty('--title-shift-x', titleShiftX.toFixed(3));
					title.style.setProperty('--title-shift-y', titleShiftY.toFixed(3));
					title.style.setProperty('--title-tilt', titleTilt.toFixed(3));
					title.style.setProperty('--title-glow', titleGlow.toFixed(3));
				}

				camera.position.x += (livePointerX * cameraRangeX - camera.position.x) * 0.028;
				camera.position.y += (-livePointerY * cameraRangeY - camera.position.y) * 0.028;
				camera.position.z += (targetCameraZ - camera.position.z) * 0.03;

				cameraAimTarget.set(
					livePointerX * lookRangeX,
					-livePointerY * lookRangeY,
					-30,
				);
				cameraAim.lerp(cameraAimTarget, 0.045);
				camera.lookAt(cameraAim);

				points.rotation.y = 0.08 + Math.sin(waveTime * 0.08) * 0.01;
				points.rotation.x = -0.08 + Math.cos(waveTime * 0.06) * 0.008;
				points.rotation.z = -0.04 + Math.sin(waveTime * 0.12) * 0.003;
				bloomPoints.rotation.y = points.rotation.y;
				bloomPoints.rotation.x = points.rotation.x;
				bloomPoints.rotation.z = points.rotation.z;
				emissivePoints.rotation.y = points.rotation.y;
				emissivePoints.rotation.x = points.rotation.x;
				emissivePoints.rotation.z = points.rotation.z;
			} else {
				pointer.x += (0 - pointer.x) * 0.05;
				pointer.y += (0 - pointer.y) * 0.05;
				vortexAnchor.x += (vortexAnchorTarget.x - vortexAnchor.x) * 0.08;
				vortexAnchor.y += (vortexAnchorTarget.y - vortexAnchor.y) * 0.08;
				if (title) {
					title.style.setProperty('--title-shift-x', '0');
					title.style.setProperty('--title-shift-y', '0');
					title.style.setProperty('--title-tilt', '0');
					title.style.setProperty('--title-glow', '0');
				}
				camera.position.x += (0 - camera.position.x) * 0.02;
				camera.position.y += (0 - camera.position.y) * 0.02;
				camera.position.z += (18 - camera.position.z) * 0.02;
				cameraAimTarget.set(0, 0, -30);
				cameraAim.lerp(cameraAimTarget, 0.03);
				camera.lookAt(cameraAim);
			}

			renderer.render(scene, camera);
		};

		animate(0);

		const cleanup = () => {
			window.cancelAnimationFrame(frameId);
			resizeObserver.disconnect();
			frame.removeEventListener('pointerenter', onPointerEnter);
			frame.removeEventListener('pointermove', onPointerMove);
			frame.removeEventListener('pointerleave', onPointerLeave);
			frame.removeEventListener('pointercancel', onPointerCancel);
			if (title) {
				title.style.removeProperty('--title-shift-x');
				title.style.removeProperty('--title-shift-y');
				title.style.removeProperty('--title-tilt');
				title.style.removeProperty('--title-glow');
			}
			hero.style.removeProperty('--vortex-center-x');
			hero.style.removeProperty('--vortex-center-y');
			frame.style.removeProperty('--vortex-center-x');
			frame.style.removeProperty('--vortex-center-y');
			geometry.dispose();
			material.dispose();
			bloomMaterial.dispose();
			emissiveMaterial.dispose();
			sprite?.dispose();
			renderer.dispose();
		};

		window.addEventListener('pagehide', cleanup, { once: true });
	}

	containers.forEach(mountHeroField);
</script>

<style>
	.hero-particles-frame {
		position: relative;
		width: 100%;
		height: min(78vh, 900px);
		margin-inline: auto;
		border-radius: 0;
		overflow: visible;
		background: transparent;
		cursor: default;
		touch-action: auto;
	}

	.hero-particles-canvas {
		position: absolute;
		inset: -10%;
		pointer-events: none;
		cursor: inherit;
		-webkit-mask-image: radial-gradient(circle at var(--vortex-center-x, 50%) var(--vortex-center-y, 50%), rgba(0, 0, 0, 1) 0 18%, rgba(0, 0, 0, 0.96) 34%, rgba(0, 0, 0, 0.6) 54%, transparent 82%);
		mask-image: radial-gradient(circle at var(--vortex-center-x, 50%) var(--vortex-center-y, 50%), rgba(0, 0, 0, 1) 0 18%, rgba(0, 0, 0, 0.96) 34%, rgba(0, 0, 0, 0.6) 54%, transparent 82%);
	}

	.hero-particles-canvas :global(canvas) {
		display: block;
		width: 100%;
		height: 100%;
		cursor: inherit;
		pointer-events: none;
	}
</style>
