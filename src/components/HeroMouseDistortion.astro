<div class="hero-distortion-shader" data-hero-distortion-shader aria-hidden="true"></div>

<script type="module" is:inline>
	import * as THREE from 'https://esm.sh/three@0.161.0';

	const containers = document.querySelectorAll('[data-hero-distortion-shader]');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const hasFinePointer = window.matchMedia('(pointer: fine)').matches;

	const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
	const lerp = (start, end, progress) => start + (end - start) * progress;

	const vertexShader = `
		varying vec2 vUv;

		void main() {
			vUv = uv;
			gl_Position = vec4(position.xy, 0.0, 1.0);
		}
	`;

	const fragmentShader = `
		precision highp float;

		uniform vec2 uResolution;
		uniform vec2 uMouse;
		uniform vec2 uVelocity;
		uniform float uTime;
		uniform float uIntensity;
		uniform float uHeroOpacity;
		varying vec2 vUv;

		float hash(vec2 p) {
			return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
		}

		float noise(vec2 p) {
			vec2 i = floor(p);
			vec2 f = fract(p);
			vec2 u = f * f * (3.0 - 2.0 * f);
			float a = hash(i);
			float b = hash(i + vec2(1.0, 0.0));
			float c = hash(i + vec2(0.0, 1.0));
			float d = hash(i + vec2(1.0, 1.0));
			return mix(a, b, u.x) + (c - a) * u.y * (1.0 - u.x) + (d - b) * u.x * u.y;
		}

		void main() {
			vec2 uv = vUv;
			vec2 delta = uv - uMouse;
			float aspect = uResolution.x / max(uResolution.y, 1.0);
			delta.x *= aspect;

			float distanceFromMouse = length(delta);
			float wake = smoothstep(0.22, 0.0, distanceFromMouse);
			float lens = smoothstep(0.105, 0.0, distanceFromMouse);
			float ringA = 1.0 - smoothstep(0.005, 0.022, abs(distanceFromMouse - 0.058));
			float ringB = 1.0 - smoothstep(0.008, 0.034, abs(distanceFromMouse - 0.115));
			float velocityAmount = clamp(length(uVelocity) * 9.0, 0.0, 1.0);
			float ripple = sin(distanceFromMouse * 74.0 - uTime * 4.2) * 0.5 + 0.5;
			float grain = noise(uv * vec2(32.0, 18.0) + uTime * 0.35);

			vec2 direction = normalize(delta + vec2(0.0001));
			float directionalGlint = max(0.0, dot(direction, normalize(vec2(uVelocity.x * aspect, uVelocity.y) + vec2(0.001))));
			float scanShear = sin((uv.y + ripple * 0.018 + uTime * 0.04) * uResolution.y * 0.55) * 0.5 + 0.5;
			float caustic = pow(lens, 1.7) * (0.55 + ripple * 0.45);
			float contour = max(ringA * 0.9, ringB * 0.34);
			float flow = directionalGlint * wake * velocityAmount;
			float mask = clamp(caustic * 0.55 + contour + flow * 0.62, 0.0, 1.0);

			vec3 emerald = vec3(0.1, 0.98, 0.62);
			vec3 mint = vec3(0.74, 1.0, 0.88);
			vec3 coldWhite = vec3(0.95, 1.0, 0.97);
			vec3 color = mix(emerald, mint, ripple);
			color = mix(color, coldWhite, ringA * 0.58 + scanShear * lens * 0.16);
			color += vec3(0.0, 0.23, 0.12) * flow;
			color -= vec3(0.08, 0.0, 0.12) * (1.0 - scanShear) * lens;
			color += (grain - 0.5) * 0.055;

			float alpha = mask * uIntensity * uHeroOpacity;
			alpha *= 0.42 + velocityAmount * 0.34;
			alpha = clamp(alpha, 0.0, 0.58);

			gl_FragColor = vec4(color, alpha);
		}
	`;

	function mountHeroDistortion(container) {
		if (container.dataset.ready === 'true' || prefersReducedMotion || !hasFinePointer) return;
		container.dataset.ready = 'true';

		const stage = container.closest('[data-z-space]');
		if (!stage) return;

		const scene = new THREE.Scene();
		const camera = new THREE.Camera();
		const renderer = new THREE.WebGLRenderer({
			alpha: true,
			antialias: false,
			powerPreference: 'high-performance',
		});
		renderer.setClearColor(0x000000, 0);
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.35));
		container.appendChild(renderer.domElement);

		const uniforms = {
			uResolution: { value: new THREE.Vector2(1, 1) },
			uMouse: { value: new THREE.Vector2(0.5, 0.5) },
			uVelocity: { value: new THREE.Vector2(0, 0) },
			uTime: { value: 0 },
			uIntensity: { value: 0 },
			uHeroOpacity: { value: 1 },
		};
		const material = new THREE.ShaderMaterial({
			uniforms,
			vertexShader,
			fragmentShader,
			transparent: true,
			depthTest: false,
			depthWrite: false,
			blending: THREE.AdditiveBlending,
		});
		const mesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material);
		scene.add(mesh);

		const mouse = new THREE.Vector2(0.5, 0.5);
		const mouseTarget = new THREE.Vector2(0.5, 0.5);
		const velocity = new THREE.Vector2(0, 0);
		const velocityTarget = new THREE.Vector2(0, 0);
		let targetIntensity = 0;
		let targetHeroOpacity = 1;
		let frameId = 0;
		let lastPointer = null;
		let isVisible = true;
		let observer = null;

		const readHeroOpacity = () => {
			const value = Number.parseFloat(getComputedStyle(stage).getPropertyValue('--hero-opacity'));
			targetHeroOpacity = Number.isFinite(value) ? clamp(value, 0, 1) : 1;
			startAnimation();
		};

		const resize = () => {
			const width = Math.max(1, container.clientWidth);
			const height = Math.max(1, container.clientHeight);
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.35));
			renderer.setSize(width, height, false);
			uniforms.uResolution.value.set(width, height);
			startAnimation();
		};

		const updatePointer = (event) => {
			const rect = container.getBoundingClientRect();
			if (!rect.width || !rect.height) return;

			const x = clamp((event.clientX - rect.left) / rect.width, 0, 1);
			const y = clamp(1 - (event.clientY - rect.top) / rect.height, 0, 1);
			mouseTarget.set(x, y);

			if (lastPointer) {
				const dx = (event.clientX - lastPointer.x) / rect.width;
				const dy = -(event.clientY - lastPointer.y) / rect.height;
				velocityTarget.set(dx, dy);
				targetIntensity = clamp(targetIntensity + Math.hypot(dx, dy) * 24, 0.22, 1);
			} else {
				targetIntensity = 0.34;
			}

			lastPointer = { x: event.clientX, y: event.clientY };
			startAnimation();
		};

		const onPointerLeave = () => {
			lastPointer = null;
			targetIntensity = 0;
			velocityTarget.set(0, 0);
			startAnimation();
		};

		const startAnimation = () => {
			if (!frameId && isVisible) {
				frameId = window.requestAnimationFrame(animate);
			}
		};

		const stopAnimation = () => {
			if (frameId) {
				window.cancelAnimationFrame(frameId);
				frameId = 0;
			}
		};

		const animate = (time) => {
			frameId = 0;
			if (!isVisible) return;

			mouse.lerp(mouseTarget, 0.18);
			velocity.lerp(velocityTarget, 0.12);
			uniforms.uTime.value = time * 0.001;
			uniforms.uMouse.value.copy(mouse);
			uniforms.uVelocity.value.copy(velocity);
			uniforms.uIntensity.value = lerp(uniforms.uIntensity.value, targetIntensity, 0.12);
			uniforms.uHeroOpacity.value = lerp(uniforms.uHeroOpacity.value, targetHeroOpacity, 0.1);

			targetIntensity *= 0.955;
			velocityTarget.multiplyScalar(0.9);
			renderer.render(scene, camera);

			const stillAnimating =
				uniforms.uIntensity.value > 0.008 ||
				Math.abs(uniforms.uHeroOpacity.value - targetHeroOpacity) > 0.008 ||
				velocity.length() > 0.0008 ||
				mouse.distanceTo(mouseTarget) > 0.0008;

			if (stillAnimating) {
				startAnimation();
			}
		};

		window.addEventListener('resize', resize);
		stage.addEventListener('pointermove', updatePointer, { passive: true });
		stage.addEventListener('pointerleave', onPointerLeave);
		stage.addEventListener('z-space-progress', readHeroOpacity);

		const resizeObserver = new ResizeObserver(resize);
		resizeObserver.observe(container);
		resize();
		readHeroOpacity();

		observer = new IntersectionObserver(
			([entry]) => {
				isVisible = Boolean(entry?.isIntersecting);
				if (isVisible) {
					startAnimation();
				} else {
					stopAnimation();
				}
			},
			{ rootMargin: '20% 0px' },
		);
		observer.observe(stage);

		const cleanup = () => {
			stopAnimation();
			window.removeEventListener('resize', resize);
			stage.removeEventListener('pointermove', updatePointer);
			stage.removeEventListener('pointerleave', onPointerLeave);
			stage.removeEventListener('z-space-progress', readHeroOpacity);
			resizeObserver.disconnect();
			observer?.disconnect();
			mesh.geometry.dispose();
			material.dispose();
			renderer.dispose();
		};

		window.addEventListener('pagehide', cleanup, { once: true });
	}

	containers.forEach(mountHeroDistortion);
</script>

<style>
	.hero-distortion-shader {
		position: absolute;
		inset: 0;
		z-index: 4;
		overflow: hidden;
		pointer-events: none;
		mix-blend-mode: screen;
		opacity: 0.95;
		contain: strict;
	}

	.hero-distortion-shader :global(canvas) {
		display: block;
		width: 100%;
		height: 100%;
	}

	@media (pointer: coarse), (prefers-reduced-motion: reduce) {
		.hero-distortion-shader {
			display: none;
		}
	}
</style>
