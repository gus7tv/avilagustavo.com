---
const { projects } = Astro.props;

const projectEntries = projects.map((project, index) => {
	const tags =
		project.data.description
			.match(/#[\w./+-]+/g)
			?.slice(0, 4)
			.map((tag) => tag.replace("#", "").replace(/\.+$/, "")) ??
		[project.data.category.toUpperCase()];

	return {
		index: String(index + 1).padStart(2, "0"),
		title: project.data.title.toUpperCase(),
		category: project.data.category.toUpperCase(),
		description: project.data.description,
		tags,
		year: new Date(project.data.pubDate).getFullYear(),
		heroImage:
			typeof project.data.heroImage === "string"
				? project.data.heroImage
				: project.data.heroImage.src,
		previewVideo: project.data.previewVideo ?? null,
		url: project.data.url,
	};
});

const totalProjectsLabel = String(projectEntries.length).padStart(2, "0");
---

<section
	class="projects-monitor"
	data-project-monitor
	data-project-count={projectEntries.length}
	aria-label="Featured projects"
>
	<div class="projects-monitor__hud">
		<span>FEATURED PROJECTS</span>
		<div class="projects-monitor__controls">
			{projectEntries.length > 1 && (
				<button
					type="button"
					class="projects-monitor__nav"
					data-project-prev
					aria-label="Previous project"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path d="M15 5 8 12l7 7" />
					</svg>
				</button>
			)}
			<span class="projects-monitor__hud-counter">
				<strong data-project-current>01</strong>
				<small>{`/ ${totalProjectsLabel}`}</small>
			</span>
			{projectEntries.length > 1 && (
				<button
					type="button"
					class="projects-monitor__nav"
					data-project-next
					aria-label="Next project"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path d="m9 5 7 7-7 7" />
					</svg>
				</button>
			)}
		</div>
	</div>

	<div class="projects-monitor__frame">
		<a
			class="projects-monitor__media-link"
			data-project-link
			href={projectEntries[0]?.url ?? "#"}
			target="_blank"
			rel="noreferrer"
			aria-label={`Open project ${projectEntries[0]?.title ?? "active"}`}
		>
			<div class="projects-monitor__media-shell" data-project-shell>
				<div class="projects-monitor__media-layer" data-project-layer="base">
					<img data-project-image alt="" decoding="async" />
					<video data-project-video muted loop playsinline preload="auto" aria-hidden="true"></video>
				</div>
				<div class="projects-monitor__media-layer projects-monitor__media-layer--overlay" data-project-layer="overlay">
					<img data-project-image alt="" decoding="async" />
					<video data-project-video muted loop playsinline preload="auto" aria-hidden="true"></video>
				</div>
				<div class="projects-monitor__media-shade" aria-hidden="true"></div>
				<div class="projects-monitor__media-noise" aria-hidden="true"></div>
				<div class="projects-monitor__media-grid" aria-hidden="true"></div>
			</div>
		</a>

		<div class="projects-monitor__frame-line projects-monitor__frame-line--bottom" aria-hidden="true"></div>
		<div class="projects-monitor__ticks" aria-hidden="true">
			{
				Array.from({ length: 14 }, (_, index) => (
					<span style={`--tick-index:${index};`}></span>
				))
			}
		</div>

		<div class="projects-monitor__copy-backdrop" aria-hidden="true"></div>

		<div class="projects-monitor__copy-stack">
			{
				projectEntries.map((project, index) => (
					<div class="projects-monitor__copy" data-project-copy data-copy-index={index}>
						<h3>{project.title}</h3>
						{project.tags.length > 0 && (
							<div class="projects-monitor__tags">
								<span class="projects-monitor__tags-label">Made with</span>
								<ul class="projects-monitor__tag-list">
									{project.tags.map((tag) => (
										<li class="projects-monitor__tag">{tag}</li>
									))}
								</ul>
							</div>
						)}
					</div>
				))
			}
		</div>

	</div>
</section>

<script type="module" define:vars={{ projectEntries }}>
	const clampValue = (value, min, max) => Math.min(max, Math.max(min, value));
	const easeHoverAxis = (value) => Math.sin(value * (Math.PI / 2));
	const AUTO_ADVANCE_MS = 30000;

	const mountProjectMonitor = () => {
		document.querySelectorAll("[data-project-monitor]").forEach((root) => {
			if (root.dataset.ready === "true") return;
			root.dataset.ready = "true";

			const stage = root.closest("[data-z-space]");
			const frame = root.querySelector(".projects-monitor__frame");
			const mediaLink = root.querySelector("[data-project-link]");
			const shell = root.querySelector("[data-project-shell]");
			const copies = [...root.querySelectorAll("[data-project-copy]")];
			const currentLabel = root.querySelector("[data-project-current]");
			const prevButton = root.querySelector("[data-project-prev]");
			const nextButton = root.querySelector("[data-project-next]");
			const layers = [...root.querySelectorAll("[data-project-layer]")].map((element) => ({
				element,
				image: element.querySelector("[data-project-image]"),
				video: element.querySelector("[data-project-video]"),
				currentProjectKey: "",
				assignedIndex: null,
				videoReady: false,
				cleanupReady: null,
			}));

			if (!stage || !frame || !mediaLink || !shell || layers.length !== 2) return;

			const maxIndex = Math.max(0, projectEntries.length - 1);
			const hoverEnabled = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
			const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
			const hoverTarget = { x: 0, y: 0, lift: 0 };
			const hoverState = { x: 0, y: 0, lift: 0 };

			let frameId = 0;
			let targetIndex = 0;
			let displayIndex = 0;
			let fromIndex = 0;
			let transitionStartTime = 0;
			let transitionDuration = 0;
			let isMonitorVisible = true;
			let projectsPanelActive = false;
			let visibilityObserver = null;
			let activeVideoIndicesKey = "";
			let autoAdvanceTimer = 0;

			const requestRender = () => {
				if (!isMonitorVisible || frameId) return;
				frameId = window.requestAnimationFrame(render);
			};

			const stopRender = () => {
				if (!frameId) return;
				window.cancelAnimationFrame(frameId);
				frameId = 0;
			};

			const pauseLayerVideo = (layer) => {
				if (!layer.video) return;
				layer.video.pause();
			};

			const teardownLayer = (layer) => {
				pauseLayerVideo(layer);
				layer.cleanupReady?.();
				layer.cleanupReady = null;
				layer.videoReady = false;
			};

			const updateLayerVisibility = (layer) => {
				layer.element.dataset.videoReady = layer.videoReady ? "true" : "false";
			};

			const syncLayerProject = (layer, project) => {
				if (!layer.image || !layer.video || !project) return;

				const projectKey = `${project.index}:${project.previewVideo ?? project.heroImage}`;
				if (layer.currentProjectKey === projectKey) return;

				teardownLayer(layer);
				layer.currentProjectKey = projectKey;
				layer.image.src = project.heroImage;
				layer.image.alt = `${project.title} preview`;
				layer.image.loading = "eager";

				if (!project.previewVideo) {
					layer.video.removeAttribute("src");
					layer.video.removeAttribute("poster");
					layer.video.load();
					updateLayerVisibility(layer);
					return;
				}

				layer.video.poster = project.heroImage;
				layer.video.muted = true;
				layer.video.defaultMuted = true;
				layer.video.loop = true;
				layer.video.playsInline = true;
				layer.video.autoplay = false;
				layer.video.preload = "auto";
				layer.video.src = project.previewVideo;

				const markReady = () => {
					layer.videoReady = true;
					updateLayerVisibility(layer);
					requestRender();
				};

				const onError = () => {
					layer.videoReady = false;
					updateLayerVisibility(layer);
				};

				layer.video.addEventListener("loadeddata", markReady, { once: true });
				layer.video.addEventListener("canplay", markReady, { once: true });
				layer.video.addEventListener("playing", markReady, { once: true });
				layer.video.addEventListener("error", onError, { once: true });
				layer.cleanupReady = () => {
					layer.video.removeEventListener("loadeddata", markReady);
					layer.video.removeEventListener("canplay", markReady);
					layer.video.removeEventListener("playing", markReady);
					layer.video.removeEventListener("error", onError);
				};

				layer.video.load();
				updateLayerVisibility(layer);
			};

			const syncLayerPlayback = (layer, project, shouldPlay) => {
				if (!layer.video || !project?.previewVideo) {
					pauseLayerVideo(layer);
					return;
				}

				if (!shouldPlay) {
					pauseLayerVideo(layer);
					return;
				}

				const playAttempt = layer.video.play();
				if (playAttempt?.then) {
					playAttempt
						.then(() => {
							layer.videoReady = true;
							updateLayerVisibility(layer);
							requestRender();
						})
						.catch(() => {});
				}
			};

			const setShellHover = (x, y, lift = 0) => {
				shell.style.setProperty("--shell-tilt-x", `${y.toFixed(3)}deg`);
				shell.style.setProperty("--shell-tilt-y", `${x.toFixed(3)}deg`);
				shell.style.setProperty("--shell-lift", `${lift.toFixed(3)}px`);
			};

			const onPointerMove = (event) => {
				if (!hoverEnabled) return;
				const rect = shell.getBoundingClientRect();
				const relativeX = clampValue((event.clientX - rect.left) / rect.width, 0, 1);
				const relativeY = clampValue((event.clientY - rect.top) / rect.height, 0, 1);
				const easedX = easeHoverAxis((relativeX - 0.5) * 2);
				const easedY = easeHoverAxis((relativeY - 0.5) * 2);
				hoverTarget.x = easedX * 4.2;
				hoverTarget.y = easedY * -3.4;
				hoverTarget.lift = -3.2;
				requestRender();
			};

			const resetPointer = () => {
				hoverTarget.x = 0;
				hoverTarget.y = 0;
				hoverTarget.lift = 0;
				requestRender();
			};

			if (hoverEnabled) {
				shell.addEventListener("pointermove", onPointerMove, { passive: true });
				shell.addEventListener("pointerleave", resetPointer);
			}

			const stopAutoAdvance = () => {
				if (!autoAdvanceTimer) return;
				window.clearTimeout(autoAdvanceTimer);
				autoAdvanceTimer = 0;
			};

			const setTargetIndex = (index) => {
				const next = clampValue(index, 0, maxIndex);
				if (next === targetIndex) return;
				fromIndex = targetIndex;
				transitionStartTime = performance.now();
				const distance = Math.abs(next - fromIndex);
				transitionDuration = Math.min(820, 360 + distance * 70);
				targetIndex = next;
				requestRender();
			};

			const scheduleAutoAdvance = () => {
				stopAutoAdvance();
				if (reducedMotion || maxIndex <= 0) return;
				if (!isMonitorVisible || !projectsPanelActive) return;
				autoAdvanceTimer = window.setTimeout(() => {
					autoAdvanceTimer = 0;
					setTargetIndex(targetIndex >= maxIndex ? 0 : targetIndex + 1);
					scheduleAutoAdvance();
				}, AUTO_ADVANCE_MS);
			};

			const goToProject = (delta) => {
				const count = maxIndex + 1;
				if (count <= 1) return;
				// Loop: del último al primero y viceversa.
				setTargetIndex(((targetIndex + delta) % count + count) % count);
				scheduleAutoAdvance();
			};

			const syncPanelActive = () => {
				const active = stage.dataset.activePanel === "projects";
				if (active === projectsPanelActive) return;
				projectsPanelActive = active;
				scheduleAutoAdvance();
			};

			const onPrevClick = () => goToProject(-1);
			const onNextClick = () => goToProject(1);
			prevButton?.addEventListener("click", onPrevClick);
			nextButton?.addEventListener("click", onNextClick);

			// Swipe horizontal en el media (touch/pen) para cambiar de proyecto.
			let swipeStart = null;
			let suppressClick = false;
			let suppressClickTimer = 0;

			const onMediaPointerDown = (event) => {
				if (event.pointerType === "mouse") return;
				swipeStart = { x: event.clientX, y: event.clientY, t: performance.now() };
			};

			const onMediaPointerUp = (event) => {
				const start = swipeStart;
				swipeStart = null;
				if (!start || event.pointerType === "mouse") return;
				const dx = event.clientX - start.x;
				const dy = event.clientY - start.y;
				const dt = performance.now() - start.t;
				if (dt > 600) return;
				if (Math.abs(dx) < 42) return;
				if (Math.abs(dx) < Math.abs(dy) * 1.3) return;
				goToProject(dx < 0 ? 1 : -1);
				suppressClick = true;
				window.clearTimeout(suppressClickTimer);
				suppressClickTimer = window.setTimeout(() => {
					suppressClick = false;
				}, 350);
			};

			const onMediaPointerCancel = () => {
				swipeStart = null;
			};

			const onMediaClick = (event) => {
				if (suppressClick) {
					event.preventDefault();
					event.stopPropagation();
				}
			};

			mediaLink.addEventListener("pointerdown", onMediaPointerDown);
			mediaLink.addEventListener("pointerup", onMediaPointerUp);
			mediaLink.addEventListener("pointercancel", onMediaPointerCancel);
			mediaLink.addEventListener("click", onMediaClick);

			visibilityObserver = new IntersectionObserver(
				([entry]) => {
					isMonitorVisible = Boolean(entry?.isIntersecting);
					if (isMonitorVisible) {
						requestRender();
						scheduleAutoAdvance();
					} else {
						activeVideoIndicesKey = "";
						layers.forEach(pauseLayerVideo);
						stopRender();
						stopAutoAdvance();
					}
				},
				{ rootMargin: "25% 0px" }
			);
			visibilityObserver.observe(stage);

			stage.addEventListener("z-space-progress", syncPanelActive);

			function render() {
				frameId = 0;
				if (!isMonitorVisible) return;

				const elapsed = performance.now() - transitionStartTime;
				const rawProgress =
					transitionDuration > 0 ? clampValue(elapsed / transitionDuration, 0, 1) : 1;
				const transitionDone = rawProgress >= 1;
				// ease-out: arranca con respuesta inmediata y se asienta suave al final.
				const t = reducedMotion || transitionDone ? 1 : 1 - Math.pow(1 - rawProgress, 3);

				displayIndex = fromIndex + (targetIndex - fromIndex) * t;

				hoverState.x += (hoverTarget.x - hoverState.x) * 0.12;
				hoverState.y += (hoverTarget.y - hoverState.y) * 0.12;
				hoverState.lift += (hoverTarget.lift - hoverState.lift) * 0.14;
				setShellHover(hoverState.x, hoverState.y, hoverState.lift);

				// Cross-fade directo origen -> destino. Cada proyecto conserva su layer
				// (el video no se reinicia) y no hay discontinuidad al cruzar índices.
				const transitioning = fromIndex !== targetIndex && !transitionDone;
				const slots = transitioning ? [fromIndex, targetIndex] : [targetIndex];
				const claimed = new Set();
				const layerForIndex = new Map();

				for (const layer of layers) {
					if (slots.includes(layer.assignedIndex) && !layerForIndex.has(layer.assignedIndex)) {
						layerForIndex.set(layer.assignedIndex, layer);
						claimed.add(layer);
					}
				}
				for (const slotIndex of slots) {
					if (layerForIndex.has(slotIndex)) continue;
					const freeLayer = layers.find((layer) => !claimed.has(layer));
					if (!freeLayer) continue;
					claimed.add(freeLayer);
					layerForIndex.set(slotIndex, freeLayer);
					freeLayer.assignedIndex = slotIndex;
					syncLayerProject(freeLayer, projectEntries[slotIndex]);
				}

				const toLayer = layerForIndex.get(targetIndex);
				const fromLayer = transitioning ? layerForIndex.get(fromIndex) : null;
				const idleLayer = layers.find((layer) => !claimed.has(layer));

				if (fromLayer) {
					fromLayer.element.style.zIndex = "1";
					fromLayer.element.style.opacity = "1";
					fromLayer.element.style.transform = `scale(${(1 - t * 0.04).toFixed(4)})`;
				}

				toLayer.element.style.zIndex = "2";
				toLayer.element.style.opacity = fromLayer ? t.toFixed(3) : "1";
				toLayer.element.style.transform = `scale(${(fromLayer ? 0.96 + t * 0.04 : 1).toFixed(4)})`;

				if (idleLayer) {
					idleLayer.element.style.zIndex = "0";
					idleLayer.element.style.opacity = "0";
				}

				const activeVideoIndices = new Set();
				if (projectEntries[targetIndex]?.previewVideo) activeVideoIndices.add(targetIndex);
				if (fromLayer && projectEntries[fromIndex]?.previewVideo) {
					activeVideoIndices.add(fromIndex);
				}

				const nextVideoKey = [...activeVideoIndices].sort((a, b) => a - b).join(",");
				if (nextVideoKey !== activeVideoIndicesKey) {
					activeVideoIndicesKey = nextVideoKey;
				}

				syncLayerPlayback(
					toLayer,
					projectEntries[targetIndex],
					isMonitorVisible && activeVideoIndices.has(targetIndex)
				);
				if (fromLayer) {
					syncLayerPlayback(
						fromLayer,
						projectEntries[fromIndex],
						isMonitorVisible && activeVideoIndices.has(fromIndex)
					);
				}
				if (idleLayer) pauseLayerVideo(idleLayer);

				copies.forEach((copy, index) => {
					const offset = index - displayIndex;
					const absOffset = Math.min(Math.abs(offset), 1.6);
					const opacity = clampValue(1 - absOffset * 1.45, 0, 1);
					const translateY = offset * 28;

					copy.style.opacity = opacity.toFixed(3);
					copy.style.transform = `translate3d(0, ${translateY}px, 0)`;
					copy.style.pointerEvents = index === targetIndex ? "auto" : "none";
				});

				if (currentLabel) {
					currentLabel.textContent = String(targetIndex + 1).padStart(2, "0");
				}

				mediaLink.href = projectEntries[targetIndex]?.url ?? "#";
				mediaLink.setAttribute(
					"aria-label",
					`Open project ${projectEntries[targetIndex]?.title ?? "active"}`
				);

				if (
					activeVideoIndicesKey ||
					!transitionDone ||
					Math.abs(hoverTarget.x - hoverState.x) >= 0.01 ||
					Math.abs(hoverTarget.y - hoverState.y) >= 0.01 ||
					Math.abs(hoverTarget.lift - hoverState.lift) >= 0.01
				) {
					requestRender();
				}
			}

			syncPanelActive();
			requestRender();

			window.addEventListener(
				"pagehide",
				() => {
					stopRender();
					stopAutoAdvance();
					stage.removeEventListener("z-space-progress", syncPanelActive);
					prevButton?.removeEventListener("click", onPrevClick);
					nextButton?.removeEventListener("click", onNextClick);
					mediaLink.removeEventListener("pointerdown", onMediaPointerDown);
					mediaLink.removeEventListener("pointerup", onMediaPointerUp);
					mediaLink.removeEventListener("pointercancel", onMediaPointerCancel);
					mediaLink.removeEventListener("click", onMediaClick);
					window.clearTimeout(suppressClickTimer);
					visibilityObserver?.disconnect();
					if (hoverEnabled) {
						shell.removeEventListener("pointermove", onPointerMove);
						shell.removeEventListener("pointerleave", resetPointer);
					}
					layers.forEach((layer) => {
						teardownLayer(layer);
						layer.video?.removeAttribute("src");
						layer.video?.load();
					});
				},
				{ once: true }
			);
		});
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", mountProjectMonitor, { once: true });
	} else {
		mountProjectMonitor();
	}

	document.addEventListener("astro:page-load", mountProjectMonitor);
</script>

<style>
	@property --projects-border-angle {
		syntax: "<angle>";
		inherits: false;
		initial-value: 0deg;
	}

	.projects-monitor {
		position: relative;
		height: 100%;
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 1rem;
		color: #f0ece4;
	}

	.projects-monitor__hud {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-bottom: 0.7rem;
		border-bottom: 1px dashed rgba(255, 255, 255, 0.08);
		font-family: "Inter", sans-serif;
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(240, 236, 228, 0.78);
	}

	.projects-monitor__hud-counter {
		display: inline-flex;
		align-items: flex-end;
		gap: 0.3rem;
		line-height: 1;
	}

	.projects-monitor__hud-counter strong {
		font-family: "Bebas Neue", sans-serif;
		font-size: clamp(1.5rem, 2.2vw, 2.2rem);
		font-weight: 700;
		letter-spacing: 0;
		color: #f0ece4;
	}

	.projects-monitor__hud-counter small {
		padding-bottom: 0.12rem;
		font-family: "Inter", sans-serif;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(240, 236, 228, 0.52);
	}

	.projects-monitor__controls {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
	}

	.projects-monitor__nav {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		padding: 0;
		border: 0;
		border-radius: 999px;
		background: rgba(71, 223, 155, 0.09);
		color: rgba(240, 236, 228, 0.82);
		cursor: pointer;
		transition:
			background 200ms ease,
			color 200ms ease,
			transform 160ms ease,
			opacity 200ms ease;
		-webkit-tap-highlight-color: transparent;
	}

	.projects-monitor__nav svg {
		width: 1rem;
		height: 1rem;
		fill: none;
		stroke: currentColor;
		stroke-width: 2.2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.projects-monitor__nav:hover {
		background: rgba(71, 223, 155, 0.18);
		color: #47df9b;
	}

	.projects-monitor__nav:active {
		transform: scale(0.9);
	}

	.projects-monitor__nav:focus-visible {
		outline: 2px solid rgba(71, 223, 155, 0.6);
		outline-offset: 2px;
	}

	.projects-monitor__nav[disabled] {
		opacity: 0.26;
		cursor: not-allowed;
		pointer-events: none;
	}

	.projects-monitor__frame {
		--projects-border-angle: 0deg;
		position: relative;
		height: 100%;
		min-height: 0;
		padding: clamp(1.5rem, 3vw, 2.4rem);
		border-radius: 1.75rem;
		border: 1px solid rgba(71, 223, 155, 0.28);
		background: transparent;
		isolation: isolate;
		box-shadow:
			0 0 0 1px rgba(71, 223, 155, 0.08),
			inset 0 0 0 1px rgba(71, 223, 155, 0.08),
			0 30px 90px rgba(0, 0, 0, 0.45);
		overflow: hidden;
	}

	.projects-monitor__frame::before,
	.projects-monitor__frame::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		padding: 1px;
		pointer-events: none;
		-webkit-mask:
			linear-gradient(#000 0 0) content-box,
			linear-gradient(#000 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
