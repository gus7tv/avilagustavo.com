---
const { projects } = Astro.props;

const projectEntries = projects.map((project, index) => {
	const roleLine =
		project.data.description.match(/#[\w./+-]+/g)?.slice(0, 4).map((tag) => tag.replace("#", "")).join(" · ") ||
		project.data.category.toUpperCase();

	return {
		index: String(index + 1).padStart(2, "0"),
		title: project.data.title.toUpperCase(),
		category: project.data.category.toUpperCase(),
		description: project.data.description,
		roleLine,
		year: new Date(project.data.pubDate).getFullYear(),
		heroImage:
			typeof project.data.heroImage === "string"
				? project.data.heroImage
				: project.data.heroImage.src,
		url: project.data.url,
	};
});

const totalProjectsLabel = String(projectEntries.length).padStart(2, "0");
---

<section
	class="projects-monitor"
	data-project-monitor
	data-project-count={projectEntries.length}
	aria-label="Proyectos destacados"
>
	<div class="projects-monitor__hud">
		<span>PROYECTOS DESTACADOS</span>
		<span>SELECTION — 2022 / 2026</span>
	</div>

	<div class="projects-monitor__frame">
		<div class="projects-monitor__monitor-stage" data-project-stage aria-hidden="true"></div>
		<a
			class="projects-monitor__monitor-link"
			data-project-link
			href={projectEntries[0]?.url ?? "#"}
			target="_blank"
			rel="noreferrer"
			aria-label={`Abrir proyecto ${projectEntries[0]?.title ?? "activo"}`}
		></a>

		<div class="projects-monitor__frame-line projects-monitor__frame-line--bottom" aria-hidden="true"></div>
		<div class="projects-monitor__ticks" aria-hidden="true">
			{
				Array.from({ length: 14 }, (_, index) => (
					<span style={`--tick-index:${index};`}></span>
				))
			}
		</div>

		<div class="projects-monitor__index">
			<strong data-project-current>01</strong>
			<span>{`/ ${totalProjectsLabel}`}</span>
		</div>

		<div class="projects-monitor__meta">
			<p data-project-role>{projectEntries[0]?.roleLine ?? ""}</p>
		</div>

		<div class="projects-monitor__copy-backdrop" aria-hidden="true"></div>

		<div class="projects-monitor__copy-stack">
			{
				projectEntries.map((project, index) => (
					<div class="projects-monitor__copy" data-project-copy data-copy-index={index}>
						<p class="projects-monitor__copy-category">{project.category}</p>
						<h3>{project.title}</h3>
					</div>
				))
			}
		</div>

		<div class="projects-monitor__footer">
			<p class="projects-monitor__footer-scroll">SCROLL</p>
			<strong class="projects-monitor__footer-year" data-project-year>{projectEntries[0]?.year ?? ""}</strong>
		</div>
	</div>
</section>

<script type="module" define:vars={{ projectEntries }}>
	import * as THREE from "https://esm.sh/three@0.161.0";

	const clampValue = (value, min, max) => Math.min(max, Math.max(min, value));
	const easeHoverAxis = (value) => Math.sin(value * (Math.PI / 2));
	const guiStorageKey = "projects-monitor-3d-tuning-v4";
	const textureLoader = new THREE.TextureLoader();
	const textureCache = new Map();

	const readSavedTuning = () => {
		try {
			return JSON.parse(window.localStorage.getItem(guiStorageKey) || "{}");
		} catch {
			return {};
		}
	};

	const makeTuningDefaults = () => ({
		wrapOffsetY: 9,
		wrapOffsetX: -27,
		monitorScale: 0.86,
		cameraY: -1.61,
		cameraZ: 14.34,
		lookAtY: -0.42,
		lookAtZ: -0.75,
		rigRotX: -0.025,
		rigRotY: -0.32,
		rigRotZ: -0.04,
		rigPosY: -0.44,
		rigPosX: 0.32,
		hoverRotX: 0.17,
		hoverRotY: 0.2,
		hoverRotZ: -0.015,
		hoverShiftX: -0.69,
		hoverShiftY: 0.1,
		cameraHoverX: 0.44,
		cameraHoverY: -0.14,
		hoverEase: 0.045,
		floatAmount: 0.04,
		floatSpeed: 1.02,
		blendShift: 0.09,
		blendScale: 0.023,
		ambientIntensity: 0,
		hemiIntensity: 0,
		keyIntensity: 0,
		rimIntensity: 14,
	});

	const createPlaceholderTexture = () => {
		const canvas = document.createElement("canvas");
		canvas.width = 32;
		canvas.height = 32;
		const context = canvas.getContext("2d");
		if (context) {
			const gradient = context.createLinearGradient(0, 0, 32, 32);
			gradient.addColorStop(0, "#101217");
			gradient.addColorStop(1, "#050505");
			context.fillStyle = gradient;
			context.fillRect(0, 0, 32, 32);
		}
		const texture = new THREE.CanvasTexture(canvas);
		texture.colorSpace = THREE.SRGBColorSpace;
		return texture;
	};

	const placeholderTexture = createPlaceholderTexture();

	const createGlowTexture = () => {
		const canvas = document.createElement("canvas");
		canvas.width = 256;
		canvas.height = 256;
		const context = canvas.getContext("2d");
		if (context) {
			const gradient = context.createRadialGradient(128, 128, 8, 128, 128, 128);
			gradient.addColorStop(0, "rgba(160,255,222,0.95)");
			gradient.addColorStop(0.25, "rgba(71,223,155,0.32)");
			gradient.addColorStop(0.58, "rgba(71,223,155,0.08)");
			gradient.addColorStop(1, "rgba(71,223,155,0)");
			context.fillStyle = gradient;
			context.fillRect(0, 0, 256, 256);
		}
		const texture = new THREE.CanvasTexture(canvas);
		texture.colorSpace = THREE.SRGBColorSpace;
		return texture;
	};

	const loadTexture = async (src) => {
		if (!src) return placeholderTexture;
		if (textureCache.has(src)) return textureCache.get(src);
		const texture = await textureLoader.loadAsync(src);
		texture.colorSpace = THREE.SRGBColorSpace;
		texture.anisotropy = 4;
		textureCache.set(src, texture);
		return texture;
	};

	const mountProjectMonitor = async () => {
		document.querySelectorAll("[data-project-monitor]").forEach(async (root) => {
			if (root.dataset.ready === "true") return;
			root.dataset.ready = "true";

			const stage = root.closest("[data-z-space]");
			const frame = root.querySelector(".projects-monitor__frame");
			const sceneHost = root.querySelector("[data-project-stage]");
			const monitorLink = root.querySelector("[data-project-link]");
			const copies = [...root.querySelectorAll("[data-project-copy]")];
			const currentLabel = root.querySelector("[data-project-current]");
			const roleLabel = root.querySelector("[data-project-role]");
			const yearLabel = root.querySelector("[data-project-year]");

			if (!stage || !frame || !sceneHost || !monitorLink) return;

			const tuningDefaults = makeTuningDefaults();
			const savedTuning = readSavedTuning();
			const tuning = {
				...tuningDefaults,
				...Object.fromEntries(
					Object.entries(savedTuning).filter(([key]) => key in tuningDefaults)
				),
			};
			const headerParticleTone = "#d7fff1";

			const renderer = new THREE.WebGLRenderer({
				alpha: true,
				antialias: true,
				powerPreference: "high-performance",
			});
			renderer.setClearColor(0x000000, 0);
			renderer.outputColorSpace = THREE.SRGBColorSpace;
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
			sceneHost.appendChild(renderer.domElement);

			const scene = new THREE.Scene();
			const camera = new THREE.PerspectiveCamera(23, 1, 0.1, 40);
			camera.position.set(0, 0.2, 13.2);

			const glowTexture = createGlowTexture();

			const ambientLight = new THREE.AmbientLight(0xffffff, 1.15);
			scene.add(ambientLight);

			const hemiLight = new THREE.HemisphereLight(0x90ffd6, 0x080808, 1.2);
			hemiLight.position.set(0, 6, 0);
			scene.add(hemiLight);

			const keyLight = new THREE.DirectionalLight(0xffffff, 1.35);
			keyLight.position.set(6, 8, 10);
			scene.add(keyLight);

			const rimLight = new THREE.PointLight(headerParticleTone, 7, 24, 2);
			rimLight.position.set(-6, 1.5, 7);
			scene.add(rimLight);

			const rig = new THREE.Group();
			scene.add(rig);

			const backdropMaterial = new THREE.MeshStandardMaterial({
				color: 0x070908,
				roughness: 0.92,
				metalness: 0.06,
			});
			const backdrop = new THREE.Mesh(new THREE.PlaneGeometry(1, 1), backdropMaterial);
			backdrop.position.set(0, -0.2, -6.8);
			scene.add(backdrop);

			const backdropGlow = new THREE.Mesh(
				new THREE.PlaneGeometry(1, 1),
				new THREE.MeshBasicMaterial({
					map: glowTexture,
					transparent: true,
					opacity: 0.3,
					depthWrite: false,
					blending: THREE.AdditiveBlending,
				})
			);
			backdropGlow.position.set(0, -0.35, -6.4);
			scene.add(backdropGlow);

			const shellMaterial = new THREE.MeshPhysicalMaterial({
				color: 0x1c1b1c,
				roughness: 0.48,
				metalness: 0.72,
				clearcoat: 0.65,
				clearcoatRoughness: 0.2,
			});
			const trimMaterial = new THREE.MeshStandardMaterial({
				color: 0x3d3937,
				roughness: 0.38,
				metalness: 0.64,
			});
			const standMaterial = new THREE.MeshStandardMaterial({
				color: 0x201f20,
				roughness: 0.62,
				metalness: 0.42,
			});
			const glassMaterial = new THREE.MeshPhysicalMaterial({
				color: 0xffffff,
				transparent: true,
				opacity: 0.08,
				roughness: 0.14,
				metalness: 0.18,
				clearcoat: 1,
				clearcoatRoughness: 0.1,
			});

			const shell = new THREE.Mesh(new THREE.BoxGeometry(8.8, 5.45, 0.7), shellMaterial);
			rig.add(shell);

			const screenGeometry = new THREE.PlaneGeometry(8.34, 5.08);
			const screenBaseMaterial = new THREE.MeshBasicMaterial({
				map: placeholderTexture,
				toneMapped: false,
			});
			const screenOverlayMaterial = new THREE.MeshBasicMaterial({
				map: placeholderTexture,
				toneMapped: false,
				transparent: true,
				opacity: 0,
			});
			const screenBase = new THREE.Mesh(screenGeometry, screenBaseMaterial);
			screenBase.position.z = 0.38;
			rig.add(screenBase);

			const screenOverlay = new THREE.Mesh(screenGeometry, screenOverlayMaterial);
			screenOverlay.position.z = 0.385;
			rig.add(screenOverlay);

			const glass = new THREE.Mesh(screenGeometry.clone(), glassMaterial);
			glass.position.z = 0.43;
			rig.add(glass);

			const neck = new THREE.Mesh(new THREE.BoxGeometry(1.1, 2.05, 0.48), standMaterial);
			neck.position.set(0, -3.72, -0.06);
			rig.add(neck);

			const baseUpper = new THREE.Mesh(new THREE.BoxGeometry(2.45, 0.34, 0.84), trimMaterial);
			baseUpper.position.set(0, -4.95, 0.02);
			rig.add(baseUpper);

			const baseLower = new THREE.Mesh(new THREE.BoxGeometry(3.7, 0.5, 1.35), standMaterial);
			baseLower.position.set(0, -5.42, 0.04);
			rig.add(baseLower);

			const floorShadow = new THREE.Mesh(
				new THREE.CircleGeometry(2.7, 48),
				new THREE.MeshBasicMaterial({
					color: 0x000000,
					transparent: true,
					opacity: 0.22,
					blending: THREE.NormalBlending,
				})
			);
			floorShadow.rotation.x = -Math.PI / 2;
			floorShadow.position.set(0, -5.72, 0.28);
			floorShadow.scale.set(1.55, 0.72, 1);
			scene.add(floorShadow);

			const textures = projectEntries.map(() => placeholderTexture);
			projectEntries.forEach((project, index) => {
				loadTexture(project.heroImage)
					.then((texture) => {
						textures[index] = texture;
					})
					.catch(() => {
						textures[index] = placeholderTexture;
					});
			});

			const hoverEnabled = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
			const shouldShowGui =
				window.location.search.includes("gui=1") ||
				window.location.hostname === "localhost" ||
				window.location.hostname === "127.0.0.1";
			const hoverTarget = { x: 0, y: 0 };
			const hoverState = { x: 0, y: 0 };
			let frameId = 0;
			let lastProgress = -1;
			let gui = null;
			let guiToastTimer = 0;

			const applyTuning = () => {
				ambientLight.intensity = tuning.ambientIntensity;
				hemiLight.intensity = tuning.hemiIntensity;
				keyLight.intensity = tuning.keyIntensity;
				rimLight.intensity = tuning.rimIntensity;
			};

			const saveTuning = () => {
				try {
					window.localStorage.setItem(guiStorageKey, JSON.stringify(tuning));
				} catch {}
				applyTuning();
			};

			applyTuning();

				const onPointerMove = (event) => {
				if (!hoverEnabled) return;
				const rect = frame.getBoundingClientRect();
				const relativeX = clampValue((event.clientX - rect.left) / rect.width, 0, 1);
				const relativeY = clampValue((event.clientY - rect.top) / rect.height, 0, 1);
				hoverTarget.x = easeHoverAxis((relativeX - 0.5) * 2);
				hoverTarget.y = easeHoverAxis((relativeY - 0.5) * 2);
			};

			const resetPointer = () => {
				hoverTarget.x = 0;
				hoverTarget.y = 0;
			};

			if (hoverEnabled) {
				frame.addEventListener("pointermove", onPointerMove, { passive: true });
				frame.addEventListener("pointerleave", resetPointer);
			}

			const resize = () => {
				const width = Math.max(1, sceneHost.clientWidth);
				const height = Math.max(1, sceneHost.clientHeight);
				camera.aspect = width / height;
				camera.updateProjectionMatrix();
				renderer.setSize(width, height, false);

				const distance = camera.position.z - backdrop.position.z;
				const visibleHeight =
					2 * Math.tan(THREE.MathUtils.degToRad(camera.fov * 0.5)) * distance;
				const visibleWidth = visibleHeight * camera.aspect;

				backdrop.scale.set(visibleWidth * 0.98, visibleHeight * 0.96, 1);
				backdropGlow.scale.set(visibleWidth * 0.62, visibleHeight * 0.5, 1);
			};

			const resizeObserver = new ResizeObserver(resize);
			resizeObserver.observe(sceneHost);
			resize();

			if (shouldShowGui) {
				const { default: GUI } = await import("https://esm.sh/lil-gui@0.19.2");
				gui = new GUI({ title: "Projects Monitor 3D" });
				gui.domElement.style.zIndex = "120";
				gui.domElement.setAttribute("data-lenis-prevent", "true");

				const toastTuning = async (message) => {
					const output = JSON.stringify(tuning, null, 2);
					console.log("ProjectsMonitor tuning", output);
					try {
						await navigator.clipboard?.writeText(output);
					} catch {}

					window.clearTimeout(guiToastTimer);
					let toast = document.querySelector("[data-projects-monitor-gui-toast]");
					if (!toast) {
						toast = document.createElement("pre");
						toast.dataset.projectsMonitorGuiToast = "true";
						toast.style.cssText = [
							"position:fixed",
							"right:1rem",
							"bottom:1rem",
							"z-index:10000",
							"max-width:min(34rem,calc(100vw - 2rem))",
							"max-height:42vh",
							"overflow:auto",
							"margin:0",
							"padding:0.9rem 1rem",
							"border:1px solid rgba(71,223,155,0.45)",
							"background:rgba(0,0,0,0.92)",
							"color:#d9fff0",
							"font:12px/1.45 ui-monospace,SFMono-Regular,Consolas,monospace",
							"white-space:pre-wrap",
						].join(";");
						document.body.appendChild(toast);
					}
					toast.textContent = `${message}\n${output}`;
					guiToastTimer = window.setTimeout(() => {
						toast.remove();
					}, 12000);
				};

				const guiState = {
					print: () => toastTuning("Valores copiados al portapapeles:"),
					reset: () => {
						Object.assign(tuning, tuningDefaults);
						try {
							window.localStorage.removeItem(guiStorageKey);
						} catch {}
						applyTuning();
						const controllers =
							typeof gui?.controllersRecursive === "function"
								? gui.controllersRecursive()
								: gui?.controllers || [];
						controllers.forEach((controller) => controller.updateDisplay());
					},
				};

				const addPersisted = (folder, key, min, max, step, label) =>
					folder.add(tuning, key, min, max, step).name(label).onChange(saveTuning);

				const layoutFolder = gui.addFolder("Layout");
				addPersisted(layoutFolder, "wrapOffsetY", -160, 160, 1, "offset Y");
				addPersisted(layoutFolder, "wrapOffsetX", -160, 160, 1, "offset X");
				addPersisted(layoutFolder, "monitorScale", 0.7, 1.3, 0.01, "scale");

				const cameraFolder = gui.addFolder("Camera");
				addPersisted(cameraFolder, "cameraY", -2, 2, 0.01, "camera Y");
				addPersisted(cameraFolder, "cameraZ", 9, 18, 0.01, "camera Z");
				addPersisted(cameraFolder, "lookAtY", -3, 2, 0.01, "lookAt Y");
				addPersisted(cameraFolder, "lookAtZ", -2, 2, 0.01, "lookAt Z");

				const rigFolder = gui.addFolder("Monitor");
				addPersisted(rigFolder, "rigRotX", -0.4, 0.6, 0.005, "rot X");
				addPersisted(rigFolder, "rigRotY", -0.8, 0.2, 0.005, "rot Y");
				addPersisted(rigFolder, "rigRotZ", -0.2, 0.2, 0.005, "rot Z");
				addPersisted(rigFolder, "rigPosX", -2, 2, 0.01, "pos X");
				addPersisted(rigFolder, "rigPosY", -2, 2, 0.01, "pos Y");

				const hoverFolder = gui.addFolder("Hover");
				addPersisted(hoverFolder, "hoverRotX", 0, 0.4, 0.005, "hover rot X");
				addPersisted(hoverFolder, "hoverRotY", 0, 0.4, 0.005, "hover rot Y");
				addPersisted(hoverFolder, "hoverRotZ", -0.12, 0.12, 0.005, "hover rot Z");
				addPersisted(hoverFolder, "hoverShiftX", -1.2, 1.2, 0.01, "hover pos X");
				addPersisted(hoverFolder, "hoverShiftY", -1.2, 1.2, 0.01, "hover pos Y");
				addPersisted(hoverFolder, "cameraHoverX", -1, 1, 0.01, "camera hover X");
				addPersisted(hoverFolder, "cameraHoverY", -1, 1, 0.01, "camera hover Y");
				addPersisted(hoverFolder, "hoverEase", 0.02, 0.2, 0.005, "smooth");

				const motionFolder = gui.addFolder("Pantalla");
				addPersisted(motionFolder, "floatAmount", 0, 0.08, 0.001, "float amount");
				addPersisted(motionFolder, "floatSpeed", 0, 3, 0.01, "float speed");
				addPersisted(motionFolder, "blendShift", 0, 0.4, 0.005, "blend shift");
				addPersisted(motionFolder, "blendScale", 0, 0.08, 0.001, "blend scale");

				const lightFolder = gui.addFolder("Luces");
				addPersisted(lightFolder, "ambientIntensity", 0, 3, 0.01, "ambient");
				addPersisted(lightFolder, "hemiIntensity", 0, 3, 0.01, "hemisphere");
				addPersisted(lightFolder, "keyIntensity", 0, 4, 0.01, "key");
				addPersisted(lightFolder, "rimIntensity", 0, 14, 0.1, "rim");

				gui.add(guiState, "print").name("imprimir valores");
				gui.add(guiState, "reset").name("reset");
			}

			const render = (time) => {
				const projectsProgress =
					parseFloat(getComputedStyle(stage).getPropertyValue("--projects-progress")) || 0;

				const maxIndex = Math.max(0, projectEntries.length - 1);
				let floatIndex = 0;
				let activeIndex = 0;

				if (maxIndex > 0) {
					const scaledProgress = clampValue(projectsProgress * maxIndex, 0, maxIndex);
					const segmentIndex = Math.min(maxIndex - 1, Math.floor(scaledProgress));
					const segmentProgress = scaledProgress - segmentIndex;
					const transitionStart = 0.64;
					const transitionEnd = 0.84;
					const transitionProgress = clampValue(
						(segmentProgress - transitionStart) / (transitionEnd - transitionStart),
						0,
						1
					);
					const easedTransition =
						transitionProgress * transitionProgress * (3 - 2 * transitionProgress);

					floatIndex =
						projectsProgress >= 0.999 ? maxIndex : segmentIndex + easedTransition;
					activeIndex =
						projectsProgress >= 0.999
							? maxIndex
							: segmentProgress >= 0.82
								? Math.min(maxIndex, segmentIndex + 1)
								: segmentIndex;
				}

				const lowerIndex = Math.min(maxIndex, Math.floor(floatIndex));
				const upperIndex = Math.min(maxIndex, lowerIndex + 1);
				const blend = clampValue(floatIndex - lowerIndex, 0, 1);

				if (screenBaseMaterial.map !== textures[lowerIndex]) {
					screenBaseMaterial.map = textures[lowerIndex];
					screenBaseMaterial.needsUpdate = true;
				}

				if (screenOverlayMaterial.map !== textures[upperIndex]) {
					screenOverlayMaterial.map = textures[upperIndex];
					screenOverlayMaterial.needsUpdate = true;
				}

				screenOverlayMaterial.opacity = blend;
				screenBase.position.x = blend * -tuning.blendShift;
				screenOverlay.position.x = (1 - blend) * tuning.blendShift;
				screenBase.scale.setScalar(1 - blend * tuning.blendScale);
				screenOverlay.scale.setScalar((1 - tuning.blendScale) + blend * tuning.blendScale);

				hoverState.x += (hoverTarget.x - hoverState.x) * tuning.hoverEase;
				hoverState.y += (hoverTarget.y - hoverState.y) * tuning.hoverEase;

				const elapsed = time * 0.001;
				rig.rotation.x =
					tuning.rigRotX +
					hoverState.y * tuning.hoverRotX +
					Math.sin(elapsed * tuning.floatSpeed) * tuning.floatAmount;
				rig.rotation.y = tuning.rigRotY + hoverState.x * tuning.hoverRotY;
				rig.rotation.z = tuning.rigRotZ + hoverState.x * tuning.hoverRotZ;
				rig.position.x =
					tuning.rigPosX + tuning.wrapOffsetX * 0.01 + hoverState.x * tuning.hoverShiftX;
				rig.position.y =
					tuning.rigPosY - tuning.wrapOffsetY * 0.01 + hoverState.y * tuning.hoverShiftY;
				rig.scale.setScalar(tuning.monitorScale);
				backdropGlow.position.x = hoverState.x * -1.65;
				backdropGlow.position.y = -0.4 + hoverState.y * -0.78;

				camera.position.x += ((hoverState.x * tuning.cameraHoverX) - camera.position.x) * 0.05;
				camera.position.y +=
					((tuning.cameraY + hoverState.y * tuning.cameraHoverY) - camera.position.y) * 0.05;
				camera.position.z += (tuning.cameraZ - camera.position.z) * 0.05;
				camera.lookAt(0, tuning.lookAtY, tuning.lookAtZ);

				copies.forEach((copy, index) => {
					const offset = index - floatIndex;
					const absOffset = Math.min(Math.abs(offset), 1.6);
					const opacity = clampValue(1 - absOffset * 1.45, 0, 1);
					const translateY = offset * 28;

					copy.style.opacity = opacity.toFixed(3);
					copy.style.transform = `translate3d(0, ${translateY}px, 0)`;
					copy.style.pointerEvents = index === activeIndex ? "auto" : "none";
				});

				if (currentLabel) {
					currentLabel.textContent = String(activeIndex + 1).padStart(2, "0");
				}

				if (roleLabel) {
					roleLabel.textContent = projectEntries[activeIndex]?.roleLine ?? "";
				}

				if (yearLabel) {
					yearLabel.textContent = String(projectEntries[activeIndex]?.year ?? "");
				}

				monitorLink.href = projectEntries[activeIndex]?.url ?? "#";
				monitorLink.setAttribute(
					"aria-label",
					`Abrir proyecto ${projectEntries[activeIndex]?.title ?? "activo"}`
				);

				const progressDelta = Math.abs(projectsProgress - lastProgress);
				lastProgress = projectsProgress;

				renderer.render(scene, camera);

				if (
					progressDelta < 0.0008 &&
					Math.abs(hoverTarget.x - hoverState.x) < 0.001 &&
					Math.abs(hoverTarget.y - hoverState.y) < 0.001
				) {
					frameId = window.requestAnimationFrame(render);
					return;
				}

				frameId = window.requestAnimationFrame(render);
			};

			frameId = window.requestAnimationFrame(render);

			window.addEventListener(
				"pagehide",
				() => {
					window.cancelAnimationFrame(frameId);
					resizeObserver.disconnect();
					if (hoverEnabled) {
						frame.removeEventListener("pointermove", onPointerMove);
						frame.removeEventListener("pointerleave", resetPointer);
					}
					gui?.destroy();
					renderer.dispose();
					screenGeometry.dispose();
					shell.geometry.dispose();
					bezel.geometry.dispose();
					neck.geometry.dispose();
					baseUpper.geometry.dispose();
					baseLower.geometry.dispose();
					floorShadow.geometry.dispose();
					backdrop.geometry.dispose();
					backdropGlow.geometry.dispose();
					shellMaterial.dispose();
					trimMaterial.dispose();
					standMaterial.dispose();
					glassMaterial.dispose();
					backdropMaterial.dispose();
					backdropGlow.material.dispose();
					screenBaseMaterial.dispose();
					screenOverlayMaterial.dispose();
					glowTexture.dispose();
				},
				{ once: true }
			);
		});
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", mountProjectMonitor, { once: true });
	} else {
		mountProjectMonitor();
	}

	document.addEventListener("astro:page-load", mountProjectMonitor);
</script>

